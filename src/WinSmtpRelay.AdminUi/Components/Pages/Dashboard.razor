@page "/"
@using WinSmtpRelay.Core.Interfaces
@using WinSmtpRelay.Core.Models
@inject IServiceScopeFactory ScopeFactory

<h1>Dashboard</h1>

<div class="card-grid">
    <div class="card">
        <div class="label">Queue Depth</div>
        <div class="value @(queueDepth > 100 ? "warning" : "")">@queueDepth</div>
    </div>
    <div class="card">
        <div class="label">Server Uptime</div>
        <div class="value" style="font-size:1.2rem">@uptime</div>
    </div>
    <div class="card">
        <div class="label">Version</div>
        <div class="value" style="font-size:1.2rem">@version</div>
    </div>
</div>

<h2 style="font-size:1.1rem; margin-bottom:0.75rem">Recent Messages</h2>
<table>
    <thead>
        <tr>
            <th>ID</th>
            <th>Sender</th>
            <th>Recipients</th>
            <th>Status</th>
            <th>Created</th>
        </tr>
    </thead>
    <tbody>
        @if (recentMessages.Count == 0)
        {
            <tr><td colspan="5" class="text-muted">No messages in queue</td></tr>
        }
        @foreach (var msg in recentMessages)
        {
            <tr>
                <td class="mono">@msg.Id</td>
                <td>@msg.Sender</td>
                <td>@msg.Recipients</td>
                <td><span class="badge badge-@msg.Status.ToString().ToLowerInvariant()">@msg.Status</span></td>
                <td>@msg.CreatedUtc.ToString("yyyy-MM-dd HH:mm")</td>
            </tr>
        }
    </tbody>
</table>

@code {
    private int queueDepth;
    private string uptime = "";
    private string version = "";
    private IReadOnlyList<QueuedMessage> recentMessages = [];

    protected override async Task OnInitializedAsync()
    {
        using var scope = ScopeFactory.CreateScope();
        var queue = scope.ServiceProvider.GetRequiredService<IMessageQueue>();

        queueDepth = await queue.GetQueueDepthAsync();
        recentMessages = await queue.GetPendingAsync(10);

        var process = System.Diagnostics.Process.GetCurrentProcess();
        var elapsed = DateTime.Now - process.StartTime;
        uptime = elapsed.Days > 0
            ? $"{elapsed.Days}d {elapsed.Hours}h {elapsed.Minutes}m"
            : $"{elapsed.Hours}h {elapsed.Minutes}m";

        version = typeof(Dashboard).Assembly.GetName().Version?.ToString() ?? "dev";
    }
}
