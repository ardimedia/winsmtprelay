@page "/logs"
@using System.Diagnostics.Eventing.Reader
@using Microsoft.JSInterop
@inject IJSRuntime JS

<BbBreadcrumb>
    <BbBreadcrumbList>
        <BbBreadcrumbItem>
            <BbBreadcrumbLink Href="/">Home</BbBreadcrumbLink>
        </BbBreadcrumbItem>
        <BbBreadcrumbSeparator />
        <BbBreadcrumbItem>
            <BbBreadcrumbPage>Event Log</BbBreadcrumbPage>
        </BbBreadcrumbItem>
    </BbBreadcrumbList>
</BbBreadcrumb>

<div class="page-header page-header-row">
    <div>
        <h1>Event Log</h1>
        <p>
            Windows Event Log entries for WinSmtpRelay
            @if (handledUntil.HasValue)
            {
                <text> &mdash; @unhandledCount new since last review</text>
            }
        </p>
    </div>
    <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" @onclick="() => showHelp = true">
        <LucideIcon Name="info" /> About this page
    </BbButton>
</div>

<div class="search-bar">
    <div class="search-input-wrapper">
        <BbInput Placeholder="Search source or message..." Value="@searchText" ValueChanged="OnSearchChanged" />
        @if (!string.IsNullOrEmpty(searchText))
        {
            <button class="search-clear" @onclick="@(() => OnSearchChanged(""))">
                <LucideIcon Name="x" />
            </button>
        }
    </div>
    <div style="width:140px;flex-shrink:0;">
        <BbNativeSelect Value="@selectedLevel" ValueChanged="@((string v) => OnLevelChanged(v))">
            <option value="">All Levels</option>
            <option value="Information">Information</option>
            <option value="Warning">Warning</option>
            <option value="Error">Error</option>
        </BbNativeSelect>
    </div>
    <div style="width:100px;flex-shrink:0;"><BbInput Type="InputType.Number" Value="@maxEntriesStr" ValueChanged="OnMaxEntriesChanged" /></div>
    <BbButton Variant="ButtonVariant.Secondary" @onclick="RefreshLogs">
        <LucideIcon Name="refresh-cw" />
        Refresh
    </BbButton>
    <BbButton Variant="ButtonVariant.Secondary" @onclick="MarkAllHandled" Disabled="@(logEntries.Count == 0 || unhandledCount == 0)">
        <LucideIcon Name="check-check" />
        Mark all as handled
    </BbButton>
    @if (handledUntil.HasValue)
    {
        <BbButton Variant="ButtonVariant.Outline" @onclick="ResetWatermark">
            Reset
        </BbButton>
    }
    <div class="flex items-center gap-1">
        <BbSwitch Checked="showHandled" CheckedChanged="ToggleShowHandled" id="show-handled" />
        <BbLabel For="show-handled">Show handled</BbLabel>
    </div>
</div>

<BbTable Data="@visibleEntries">
    <BbTableHeader>
        <BbTableRow TData="LogEntry">
            <BbTableHeaderCell TData="LogEntry">Time</BbTableHeaderCell>
            <BbTableHeaderCell TData="LogEntry">Level</BbTableHeaderCell>
            <BbTableHeaderCell TData="LogEntry">Source</BbTableHeaderCell>
            <BbTableHeaderCell TData="LogEntry">Message</BbTableHeaderCell>
        </BbTableRow>
    </BbTableHeader>
    <BbTableBody>
        @if (visibleEntries.Count == 0)
        {
            <BbTableRow TData="LogEntry">
                <BbTableCell colspan="4" style="text-align:center;">
                    @if (logEntries.Count > 0 && !showHandled)
                    {
                        <text>All entries are handled. Toggle &ldquo;Show handled&rdquo; to see them.</text>
                    }
                    else
                    {
                        <text>No log entries found. The Windows Event Log source 'WinSmtpRelay' may not be registered.</text>
                    }
                </BbTableCell>
            </BbTableRow>
        }
        @foreach (var entry in visibleEntries)
        {
            <BbTableRow Item="@entry" class="@($"{GetRowClass(entry)} {(IsHandled(entry) ? "log-handled" : "")} log-row-clickable")" @onclick="() => selectedEntry = entry">
                <BbTableCell style="white-space:nowrap;">@entry.Time.ToString("yyyy-MM-dd HH:mm:ss")</BbTableCell>
                <BbTableCell><span class="badge-status @GetBadgeCss(entry.Level)">@entry.Level</span></BbTableCell>
                <BbTableCell>@entry.Source</BbTableCell>
                <BbTableCell>
                    @{ var parsed = ParseMessageFields(entry.Message); }
                    <table style="border-collapse:collapse;width:100%;table-layout:fixed;">
                        @foreach (var field in parsed)
                        {
                            <tr>
                                <td style="color:var(--muted-foreground);font-size:0.75rem;white-space:nowrap;padding:0 0.5rem 0 0;vertical-align:top;width:70px;">@field.Label:</td>
                                <td style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis;padding:0;">@field.Value</td>
                            </tr>
                        }
                    </table>
                </BbTableCell>
            </BbTableRow>
        }
    </BbTableBody>
</BbTable>

<BbDialog Open="@(selectedEntry is not null)" OpenChanged="@(open => { if (!open) selectedEntry = null; })">
    <BbDialogContent>
        @if (selectedEntry is not null)
        {
            <BbDialogHeader>
                <BbDialogTitle>
                    <span class="badge-status @GetBadgeCss(selectedEntry.Level)">@selectedEntry.Level</span>
                </BbDialogTitle>
                <BbDialogDescription>@selectedEntry.Time.ToString("yyyy-MM-dd HH:mm:ss") &mdash; @selectedEntry.Source</BbDialogDescription>
            </BbDialogHeader>
            <div style="font-size:0.875rem;line-height:1.6;max-height:60vh;overflow-y:auto;">
                @foreach (var field in ParseMessageFields(selectedEntry.Message))
                {
                    <div style="margin-bottom:0.5rem;">
                        <strong style="color:var(--muted-foreground);">@field.Label</strong><br />
                        <span style="word-break:break-word;">@field.Value</span>
                    </div>
                }
            </div>
            <BbDialogFooter>
                <BbDialogClose>
                    <BbButton Variant="ButtonVariant.Outline">Close</BbButton>
                </BbDialogClose>
            </BbDialogFooter>
        }
    </BbDialogContent>
</BbDialog>

<BbDialog @bind-Open="showHelp">
    <BbDialogContent>
        <BbDialogHeader>
            <BbDialogTitle>About the Event Log</BbDialogTitle>
            <BbDialogDescription>Windows Event Log viewer for WinSmtpRelay</BbDialogDescription>
        </BbDialogHeader>
        <div style="font-size:0.875rem;line-height:1.6;">
            <p>
                This page reads entries from the <strong>Windows Event Log</strong> (Application log) written by
                the WinSmtpRelay service. It provides a convenient way to inspect service-level events without
                opening the Windows Event Viewer.
            </p>
            <h4 style="margin-top:1rem;">Event levels</h4>
            <ul style="padding-left:1.25rem;">
                <li><strong>Information</strong> &mdash; normal operations: service start/stop, configuration loaded, delivery summaries.</li>
                <li><strong>Warning</strong> &mdash; non-critical issues: temporary delivery failures, rate-limit hits, certificate expiry warnings.</li>
                <li><strong>Error</strong> &mdash; critical failures: unhandled exceptions, database errors, TLS handshake failures.</li>
            </ul>
            <h4 style="margin-top:1rem;">Search &amp; filtering</h4>
            <p>
                Use the <strong>search box</strong> to filter entries by source or message text. The
                <strong>level dropdown</strong> filters by severity. The <strong>entry count</strong> field
                limits how many entries are loaded (default 100). Changes apply immediately. Click
                <strong>Refresh</strong> to reload entries from the Windows Event Log.
            </p>
            <h4 style="margin-top:1rem;">Marking entries as handled</h4>
            <p>
                Click <strong>Mark all as handled</strong> to acknowledge all current entries. Handled entries
                are dimmed and can be hidden with the <strong>Show handled</strong> toggle. The handled state
                is stored in your browser &mdash; each admin has their own independent view. Use
                <strong>Reset</strong> to clear the watermark and show all entries as unhandled again.
            </p>
        </div>
        <BbDialogFooter>
            <BbDialogClose>
                <BbButton Variant="ButtonVariant.Outline">Close</BbButton>
            </BbDialogClose>
        </BbDialogFooter>
    </BbDialogContent>
</BbDialog>

@code {
    private const string StorageKey = "winsmtprelay-log-handled-until";
    private const string ShowHandledKey = "winsmtprelay-log-show-handled";

    private bool showHelp;
    private List<LogEntry> logEntries = [];
    private string selectedLevel = "";
    private string searchText = "WinSmtpRelay";
    private string maxEntriesStr = "100";
    private int maxEntries => int.TryParse(maxEntriesStr, out var v) ? v : 100;

    private DateTime? handledUntil;
    private bool showHandled;
    private int unhandledCount;
    private List<LogEntry> visibleEntries = [];
    private LogEntry? selectedEntry;

    protected override void OnInitialized()
    {
        LoadLogs();
        UpdateVisibleEntries();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        await ReadWatermark();
        var showHandledStr = await JS.InvokeAsync<string?>("localStorage.getItem", ShowHandledKey);
        showHandled = showHandledStr == "true";
        UpdateUnhandledCount();
        UpdateVisibleEntries();
        StateHasChanged();
    }

    private async Task ReadWatermark()
    {
        var stored = await JS.InvokeAsync<string?>("localStorage.getItem", StorageKey);
        if (stored is not null && DateTime.TryParse(stored, null, System.Globalization.DateTimeStyles.RoundtripKind, out var dt))
        {
            handledUntil = dt;
        }
    }

    private async Task MarkAllHandled()
    {
        var latest = logEntries.Count > 0 ? logEntries[0].Time : DateTime.UtcNow;
        handledUntil = latest;
        await JS.InvokeVoidAsync("localStorage.setItem", StorageKey, latest.ToString("O"));
        UpdateUnhandledCount();
        UpdateVisibleEntries();
    }

    private async Task ResetWatermark()
    {
        handledUntil = null;
        await JS.InvokeVoidAsync("localStorage.removeItem", StorageKey);
        UpdateUnhandledCount();
        UpdateVisibleEntries();
    }

    private async Task ToggleShowHandled(bool value)
    {
        showHandled = value;
        await JS.InvokeVoidAsync("localStorage.setItem", ShowHandledKey, value ? "true" : "false");
        UpdateVisibleEntries();
    }

    private Task OnSearchChanged(string value)
    {
        searchText = value;
        UpdateVisibleEntries();
        return Task.CompletedTask;
    }

    private async Task OnLevelChanged(string value)
    {
        selectedLevel = value;
        await RefreshLogs();
    }

    private async Task OnMaxEntriesChanged(string value)
    {
        maxEntriesStr = value;
        await RefreshLogs();
    }

    private async Task RefreshLogs()
    {
        LoadLogs();
        await ReadWatermark();
        UpdateUnhandledCount();
        UpdateVisibleEntries();
    }

    private void LoadLogs()
    {
        logEntries.Clear();

        try
        {
            if (!OperatingSystem.IsWindows()) return;

            var query = "*[System[Provider[@Name='WinSmtpRelay'] or Provider[@Name='.NET Runtime']]]";
            using var logReader = new EventLogReader(new EventLogQuery("Application", PathType.LogName, query));

            var entries = new List<LogEntry>();
            EventRecord? record;
            while ((record = logReader.ReadEvent()) is not null)
            {
                using (record)
                {
                    var level = record.Level switch
                    {
                        (byte)StandardEventLevel.Error or (byte)StandardEventLevel.Critical => "Error",
                        (byte)StandardEventLevel.Warning => "Warning",
                        _ => "Information"
                    };

                    if (!string.IsNullOrEmpty(selectedLevel) && level != selectedLevel)
                        continue;

                    var message = record.FormatDescription() ?? "(no message)";
                    if (IsNoiseMessage(message))
                        continue;

                    entries.Add(new LogEntry(
                        record.TimeCreated ?? DateTime.MinValue,
                        level,
                        record.ProviderName ?? "Unknown",
                        message));
                }
            }

            logEntries = entries
                .OrderByDescending(e => e.Time)
                .Take(maxEntries)
                .ToList();
        }
        catch (Exception ex)
        {
            logEntries.Add(new LogEntry(DateTime.Now, "Error", "LogViewer",
                $"Failed to read Event Log: {ex.Message}"));
        }
    }

    private static bool IsNoiseMessage(string message) =>
        message.Contains("failure initializing profiling API", StringComparison.OrdinalIgnoreCase);

    private bool IsHandled(LogEntry entry) =>
        handledUntil.HasValue && entry.Time <= handledUntil.Value;

    private void UpdateUnhandledCount() =>
        unhandledCount = logEntries.Count(e => !IsHandled(e));

    private void UpdateVisibleEntries()
    {
        var entries = showHandled ? logEntries : logEntries.Where(e => !IsHandled(e));
        if (!string.IsNullOrWhiteSpace(searchText))
        {
            entries = entries.Where(e =>
                e.Source.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                e.Message.Contains(searchText, StringComparison.OrdinalIgnoreCase));
        }
        visibleEntries = entries.ToList();
    }

    private string GetRowClass(LogEntry entry) => entry.Level switch
    {
        "Error" => "row-error",
        "Warning" => "row-warning",
        _ => ""
    };

    private static string GetBadgeCss(string level) => level switch
    {
        "Error" => "badge-error",
        "Warning" => "badge-warning",
        _ => "badge-muted"
    };

    private static string Truncate(string text, int maxLen) =>
        text.Length > maxLen ? text[..maxLen] + "..." : text;

    /// <summary>
    /// Extracts the core message from .NET Runtime formatted event log entries.
    /// Input:  "Category: Some.Namespace.Class EventId: 0 Sender foo@bar.com rejected: domain bar.com not in accepted sender domains"
    /// Output: "Sender foo@bar.com rejected: domain bar.com not in accepted sender domains"
    /// </summary>
    private static string ExtractCoreMessage(string message)
    {
        // .NET Runtime format: "Category: ... EventId: N actual message"
        var eventIdMarker = "EventId: ";
        var idx = message.IndexOf(eventIdMarker, StringComparison.Ordinal);
        if (idx < 0)
            return message;

        // Skip past digits and whitespace after "EventId: "
        var pos = idx + eventIdMarker.Length;
        while (pos < message.Length && char.IsDigit(message[pos]))
            pos++;
        while (pos < message.Length && char.IsWhiteSpace(message[pos]))
            pos++;

        return pos < message.Length ? message[pos..] : message;
    }

    /// <summary>
    /// Parses a .NET Runtime event log message into structured label/value fields.
    /// </summary>
    private static List<(string Label, string Value)> ParseMessageFields(string message)
    {
        var fields = new List<(string Label, string Value)>();

        // Try to parse .NET Runtime format: "Category: X EventId: N message"
        var eventIdMarker = "EventId: ";
        var eventIdIdx = message.IndexOf(eventIdMarker, StringComparison.Ordinal);

        if (eventIdIdx >= 0)
        {
            // Extract Category
            var categoryPrefix = "Category: ";
            var catIdx = message.IndexOf(categoryPrefix, StringComparison.Ordinal);
            if (catIdx >= 0)
            {
                var catValue = message[(catIdx + categoryPrefix.Length)..eventIdIdx].Trim();
                fields.Add(("Category", catValue));
            }

            // Extract EventId (digits only) and message (everything after)
            var afterEventId = eventIdIdx + eventIdMarker.Length;
            var numberEnd = afterEventId;
            while (numberEnd < message.Length && char.IsDigit(message[numberEnd]))
                numberEnd++;

            var eventId = message[afterEventId..numberEnd];
            fields.Add(("Event ID", eventId));

            // Skip any whitespace between the number and the message text
            var msgStart = numberEnd;
            while (msgStart < message.Length && char.IsWhiteSpace(message[msgStart]))
                msgStart++;

            if (msgStart < message.Length)
                fields.Add(("Message", message[msgStart..]));
        }
        else
        {
            // Not a .NET Runtime format — show as-is
            fields.Add(("Message", message));
        }

        return fields;
    }

    private record LogEntry(DateTime Time, string Level, string Source, string Message);
}
