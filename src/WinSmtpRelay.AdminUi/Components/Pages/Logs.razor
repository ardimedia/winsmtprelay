@page "/logs"
@using System.Diagnostics
@using System.Diagnostics.Eventing.Reader

<BbBreadcrumb>
    <BbBreadcrumbList>
        <BbBreadcrumbItem>
            <BbBreadcrumbLink Href="/">Home</BbBreadcrumbLink>
        </BbBreadcrumbItem>
        <BbBreadcrumbSeparator />
        <BbBreadcrumbItem>
            <BbBreadcrumbPage>Event Log</BbBreadcrumbPage>
        </BbBreadcrumbItem>
    </BbBreadcrumbList>
</BbBreadcrumb>

<div class="page-header page-header-row">
    <div>
        <h1>Event Log</h1>
        <p>Windows Event Log entries for WinSmtpRelay</p>
    </div>
    <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" @onclick="() => showHelp = true">
        <LucideIcon Name="info" /> About this page
    </BbButton>
</div>

<div class="search-bar">
    <BbNativeSelect @bind-Value="selectedLevel">
        <option value="">All Levels</option>
        <option value="Information">Information</option>
        <option value="Warning">Warning</option>
        <option value="Error">Error</option>
    </BbNativeSelect>
    <div style="width:80px;"><BbInput Type="InputType.Number" @bind-Value="maxEntriesStr" /></div>
    <BbButton Variant="ButtonVariant.Secondary" @onclick="LoadLogs">
        <LucideIcon Name="refresh-cw" />
        Refresh
    </BbButton>
    <BbButton Variant="ButtonVariant.Destructive" @onclick="() => showClearConfirm = true" Disabled="@(logEntries.Count == 0)">
        <LucideIcon Name="eraser" />
        Clear Log
    </BbButton>
</div>

<BbTable Data="@logEntries">
    <BbTableHeader>
        <BbTableRow TData="LogEntry">
            <BbTableHeaderCell TData="LogEntry">Time</BbTableHeaderCell>
            <BbTableHeaderCell TData="LogEntry">Level</BbTableHeaderCell>
            <BbTableHeaderCell TData="LogEntry">Source</BbTableHeaderCell>
            <BbTableHeaderCell TData="LogEntry">Message</BbTableHeaderCell>
        </BbTableRow>
    </BbTableHeader>
    <BbTableBody>
        @if (logEntries.Count == 0)
        {
            <BbTableRow TData="LogEntry">
                <BbTableCell colspan="4" style="text-align:center;">No log entries found. The Windows Event Log source 'WinSmtpRelay' may not be registered.</BbTableCell>
            </BbTableRow>
        }
        @foreach (var entry in logEntries)
        {
            <BbTableRow Item="@entry" class="@GetRowClass(entry.Level)">
                <BbTableCell style="white-space:nowrap;">@entry.Time.ToString("yyyy-MM-dd HH:mm:ss")</BbTableCell>
                <BbTableCell><span class="badge-status @GetBadgeCss(entry.Level)">@entry.Level</span></BbTableCell>
                <BbTableCell>@entry.Source</BbTableCell>
                <BbTableCell>
                    @if (entry.Message.Length > 120)
                    {
                        <BbTooltip>
                            <BbTooltipTrigger>
                                <span>@Truncate(entry.Message, 120)</span>
                            </BbTooltipTrigger>
                            <BbTooltipContent>
                                <div style="max-width:400px;white-space:pre-wrap;">@entry.Message</div>
                            </BbTooltipContent>
                        </BbTooltip>
                    }
                    else
                    {
                        @entry.Message
                    }
                </BbTableCell>
            </BbTableRow>
        }
    </BbTableBody>
</BbTable>

<BbAlertDialog @bind-Open="showClearConfirm">
    <BbAlertDialogContent>
        <BbAlertDialogHeader>
            <BbAlertDialogTitle>Clear Event Log</BbAlertDialogTitle>
            <BbAlertDialogDescription>This will permanently clear all WinSmtpRelay entries from the Windows Event Log. This action cannot be undone.</BbAlertDialogDescription>
        </BbAlertDialogHeader>
        <BbAlertDialogFooter>
            <BbAlertDialogCancel>
                <BbButton Variant="ButtonVariant.Outline">Cancel</BbButton>
            </BbAlertDialogCancel>
            <BbAlertDialogAction>
                <BbButton Variant="ButtonVariant.Destructive" @onclick="ConfirmClearLogs">Clear</BbButton>
            </BbAlertDialogAction>
        </BbAlertDialogFooter>
    </BbAlertDialogContent>
</BbAlertDialog>

<BbDialog @bind-Open="showHelp">
    <BbDialogContent>
        <BbDialogHeader>
            <BbDialogTitle>About the Event Log</BbDialogTitle>
            <BbDialogDescription>Windows Event Log viewer for WinSmtpRelay</BbDialogDescription>
        </BbDialogHeader>
        <div style="font-size:0.875rem;line-height:1.6;">
            <p>
                This page reads entries from the <strong>Windows Event Log</strong> (Application log) written by
                the WinSmtpRelay service. It provides a convenient way to inspect service-level events without
                opening the Windows Event Viewer.
            </p>
            <h4 style="margin-top:1rem;">Event levels</h4>
            <ul style="padding-left:1.25rem;">
                <li><strong>Information</strong> &mdash; normal operations: service start/stop, configuration loaded, delivery summaries.</li>
                <li><strong>Warning</strong> &mdash; non-critical issues: temporary delivery failures, rate-limit hits, certificate expiry warnings.</li>
                <li><strong>Error</strong> &mdash; critical failures: unhandled exceptions, database errors, TLS handshake failures.</li>
            </ul>
            <h4 style="margin-top:1rem;">Filtering &amp; limits</h4>
            <p>
                Use the level dropdown to show only a specific severity. The entry count field limits how many
                entries are displayed (default 100). Click <strong>Refresh</strong> to reload from the Event Log.
            </p>
            <h4 style="margin-top:1rem;">Clearing the log</h4>
            <p>
                The <strong>Clear Log</strong> button permanently removes all WinSmtpRelay entries from the
                Windows Application Event Log. This requires the service to run with administrator privileges.
            </p>
        </div>
        <BbDialogFooter>
            <BbDialogClose>
                <BbButton Variant="ButtonVariant.Outline">Close</BbButton>
            </BbDialogClose>
        </BbDialogFooter>
    </BbDialogContent>
</BbDialog>

@code {
    private bool showHelp;
    private List<LogEntry> logEntries = [];
    private string selectedLevel = "";
    private string maxEntriesStr = "100";
    private bool showClearConfirm;
    private int maxEntries => int.TryParse(maxEntriesStr, out var v) ? v : 100;

    protected override void OnInitialized()
    {
        LoadLogs();
    }

    private void LoadLogs()
    {
        logEntries.Clear();

        try
        {
            if (!OperatingSystem.IsWindows()) return;

            var query = "*[System[Provider[@Name='WinSmtpRelay'] or Provider[@Name='.NET Runtime']]]";
            using var logReader = new EventLogReader(new EventLogQuery("Application", PathType.LogName, query));

            var entries = new List<LogEntry>();
            EventRecord? record;
            while ((record = logReader.ReadEvent()) is not null)
            {
                using (record)
                {
                    var level = record.Level switch
                    {
                        (byte)StandardEventLevel.Error or (byte)StandardEventLevel.Critical => "Error",
                        (byte)StandardEventLevel.Warning => "Warning",
                        _ => "Information"
                    };

                    if (!string.IsNullOrEmpty(selectedLevel) && level != selectedLevel)
                        continue;

                    entries.Add(new LogEntry(
                        record.TimeCreated ?? DateTime.MinValue,
                        level,
                        record.ProviderName ?? "Unknown",
                        record.FormatDescription() ?? "(no message)"));
                }
            }

            logEntries = entries
                .OrderByDescending(e => e.Time)
                .Take(maxEntries)
                .ToList();
        }
        catch (Exception ex)
        {
            logEntries.Add(new LogEntry(DateTime.Now, "Error", "LogViewer",
                $"Failed to read Event Log: {ex.Message}"));
        }
    }

    private void ConfirmClearLogs()
    {
        ClearLogs();
        showClearConfirm = false;
    }

    private void ClearLogs()
    {
        try
        {
            if (!OperatingSystem.IsWindows()) return;

            using var eventLog = new EventLog("Application");
            eventLog.Source = "WinSmtpRelay";
            eventLog.Clear();

            logEntries.Clear();
        }
        catch (Exception ex)
        {
            logEntries.Clear();
            logEntries.Add(new LogEntry(DateTime.Now, "Error", "LogViewer",
                $"Failed to clear Event Log: {ex.Message}. Run as Administrator to clear logs."));
        }
    }

    private static string GetRowClass(string level) => level switch
    {
        "Error" => "row-error",
        "Warning" => "row-warning",
        _ => ""
    };

    private static string GetBadgeCss(string level) => level switch
    {
        "Error" => "badge-error",
        "Warning" => "badge-warning",
        _ => "badge-muted"
    };

    private static string Truncate(string text, int maxLen) =>
        text.Length > maxLen ? text[..maxLen] + "..." : text;

    private record LogEntry(DateTime Time, string Level, string Source, string Message);
}
