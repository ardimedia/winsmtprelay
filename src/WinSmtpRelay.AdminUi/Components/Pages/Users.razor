@page "/users"
@using WinSmtpRelay.Core.Interfaces
@using WinSmtpRelay.Core.Models
@using WinSmtpRelay.Storage
@using Microsoft.EntityFrameworkCore
@inject IServiceScopeFactory ScopeFactory

<BbBreadcrumb>
    <BbBreadcrumbList>
        <BbBreadcrumbItem>
            <BbBreadcrumbLink Href="/">Home</BbBreadcrumbLink>
        </BbBreadcrumbItem>
        <BbBreadcrumbSeparator />
        <BbBreadcrumbItem>
            <BbBreadcrumbPage>Users</BbBreadcrumbPage>
        </BbBreadcrumbItem>
    </BbBreadcrumbList>
</BbBreadcrumb>

<div class="flex justify-between items-center mb-1">
    <h2>User Management</h2>
</div>

<div style="max-width:400px;">
<BbCard Class="mb-1">
    <BbCardHeader>
        <BbCardTitle>Create User</BbCardTitle>
    </BbCardHeader>
    <BbCardContent>
        <div class="form-group">
            <BbLabel>Username</BbLabel>
            <BbInput @bind-Value="newUsername" Placeholder="username" />
        </div>
        <div class="form-group">
            <BbLabel>Password</BbLabel>
            <BbInput Type="InputType.Password" @bind-Value="newPassword" Placeholder="password" />
        </div>
    </BbCardContent>
    <BbCardFooter>
        <BbButton Variant="ButtonVariant.Default" @onclick="CreateUserAsync"
                Disabled="@(string.IsNullOrWhiteSpace(newUsername) || string.IsNullOrWhiteSpace(newPassword))">
            <LucideIcon Name="plus" /> Create
        </BbButton>
        @if (!string.IsNullOrEmpty(statusMessage))
        {
            <span class="text-muted" style="margin-left:1rem">@statusMessage</span>
        }
    </BbCardFooter>
</BbCard>
</div>

@if (isLoading)
{
    <BbSkeleton Class="h-[300px] w-full" />
}
else
{
    <BbTable Data="@users">
        <BbTableHeader>
            <BbTableRow TData="RelayUser">
                <BbTableHeaderCell TData="RelayUser">ID</BbTableHeaderCell>
                <BbTableHeaderCell TData="RelayUser">Username</BbTableHeaderCell>
                <BbTableHeaderCell TData="RelayUser">Enabled</BbTableHeaderCell>
                <BbTableHeaderCell TData="RelayUser">Allowed Senders</BbTableHeaderCell>
                <BbTableHeaderCell TData="RelayUser">Rate Limit</BbTableHeaderCell>
                <BbTableHeaderCell TData="RelayUser">Created</BbTableHeaderCell>
                <BbTableHeaderCell TData="RelayUser">Actions</BbTableHeaderCell>
            </BbTableRow>
        </BbTableHeader>
        <BbTableBody>
            @if (users.Count == 0)
            {
                <BbTableRow TData="RelayUser">
                    <BbTableCell colspan="7" style="text-align:center;">No users configured</BbTableCell>
                </BbTableRow>
            }
            @foreach (var user in users)
            {
                <BbTableRow Item="@user">
                    <BbTableCell>@user.Id</BbTableCell>
                    <BbTableCell>@user.Username</BbTableCell>
                    <BbTableCell><BbBadge Variant="@(user.IsEnabled ? BadgeVariant.Default : BadgeVariant.Secondary)">@(user.IsEnabled ? "Yes" : "No")</BbBadge></BbTableCell>
                    <BbTableCell style="max-width:200px;overflow:hidden;text-overflow:ellipsis;">
                        @(string.IsNullOrEmpty(user.AllowedSenderAddresses) ? "Any" : user.AllowedSenderAddresses)
                    </BbTableCell>
                    <BbTableCell>
                        @(user.RateLimitPerMinute.HasValue ? $"{user.RateLimitPerMinute}/min" : "\u2014")
                        @(user.RateLimitPerDay.HasValue ? $", {user.RateLimitPerDay}/day" : "")
                    </BbTableCell>
                    <BbTableCell>@user.CreatedUtc.ToString("yyyy-MM-dd")</BbTableCell>
                    <BbTableCell>
                        <BbDropdownMenu>
                            <BbDropdownMenuTrigger>
                                <BbButton Size="ButtonSize.Small" Variant="ButtonVariant.Ghost">
                                    <LucideIcon Name="ellipsis" />
                                </BbButton>
                            </BbDropdownMenuTrigger>
                            <BbDropdownMenuContent>
                                <BbDropdownMenuItem @onclick="() => StartEdit(user)">
                                    <LucideIcon Name="pencil" /> Edit
                                </BbDropdownMenuItem>
                                <BbDropdownMenuSeparator />
                                <BbDropdownMenuItem @onclick="() => { deleteTargetId = user.Id; showDeleteConfirm = true; }">
                                    <LucideIcon Name="trash-2" /> Delete
                                </BbDropdownMenuItem>
                            </BbDropdownMenuContent>
                        </BbDropdownMenu>
                    </BbTableCell>
                </BbTableRow>
            }
        </BbTableBody>
    </BbTable>
}

<BbDialog @bind-Open="isEditDialogOpen">
    <BbDialogContent>
        <BbDialogHeader>
            <BbDialogTitle>Edit: @editingUser?.Username</BbDialogTitle>
            <BbDialogDescription>Modify user settings</BbDialogDescription>
        </BbDialogHeader>
        <div class="form-group">
            <BbLabel>Enabled</BbLabel>
            <BbNativeSelect @bind-Value="editEnabled">
                <option value="true">Yes</option>
                <option value="false">No</option>
            </BbNativeSelect>
        </div>
        <div class="form-group">
            <BbLabel>Allowed Sender Addresses</BbLabel>
            <BbInput @bind-Value="editAllowedSenders" Placeholder="user@example.com;noreply@example.com" />
        </div>
        <div class="form-group">
            <BbLabel>Rate Limit per Minute</BbLabel>
            <BbInput Type="InputType.Number" @bind-Value="editRatePerMinuteStr" Placeholder="unlimited" />
        </div>
        <div class="form-group">
            <BbLabel>Rate Limit per Day</BbLabel>
            <BbInput Type="InputType.Number" @bind-Value="editRatePerDayStr" Placeholder="unlimited" />
        </div>
        <BbDialogFooter>
            <BbDialogClose>
                <BbButton Variant="ButtonVariant.Outline">Cancel</BbButton>
            </BbDialogClose>
            <BbButton Variant="ButtonVariant.Default" @onclick="SaveEditAsync">Save</BbButton>
        </BbDialogFooter>
    </BbDialogContent>
</BbDialog>

<BbAlertDialog @bind-Open="showDeleteConfirm">
    <BbAlertDialogContent>
        <BbAlertDialogHeader>
            <BbAlertDialogTitle>Delete User</BbAlertDialogTitle>
            <BbAlertDialogDescription>This will permanently delete this user account. This action cannot be undone.</BbAlertDialogDescription>
        </BbAlertDialogHeader>
        <BbAlertDialogFooter>
            <BbAlertDialogCancel>
                <BbButton Variant="ButtonVariant.Outline">Cancel</BbButton>
            </BbAlertDialogCancel>
            <BbAlertDialogAction>
                <BbButton Variant="ButtonVariant.Destructive" @onclick="ConfirmDeleteAsync">Delete</BbButton>
            </BbAlertDialogAction>
        </BbAlertDialogFooter>
    </BbAlertDialogContent>
</BbAlertDialog>

@code {
    private IReadOnlyList<RelayUser> users = [];
    private string newUsername = "";
    private string newPassword = "";
    private string? statusMessage;
    private bool isLoading = true;
    private bool isEditDialogOpen;
    private bool showDeleteConfirm;
    private int deleteTargetId;

    private RelayUser? editingUser;
    private string editEnabled = "true";
    private string editAllowedSenders = "";
    private string editRatePerMinuteStr = "";
    private string editRatePerDayStr = "";

    private int? editRatePerMinute => int.TryParse(editRatePerMinuteStr, out var v) ? v : null;
    private int? editRatePerDay => int.TryParse(editRatePerDayStr, out var v) ? v : null;

    protected override async Task OnInitializedAsync() => await RefreshAsync();

    private async Task RefreshAsync()
    {
        isLoading = true;
        using var scope = ScopeFactory.CreateScope();
        var svc = scope.ServiceProvider.GetRequiredService<IUserService>();
        users = await svc.GetAllUsersAsync();
        isLoading = false;
    }

    private async Task CreateUserAsync()
    {
        using var scope = ScopeFactory.CreateScope();
        var svc = scope.ServiceProvider.GetRequiredService<IUserService>();

        var existing = await svc.GetByUsernameAsync(newUsername);
        if (existing is not null)
        {
            statusMessage = $"User '{newUsername}' already exists";
            return;
        }

        await svc.CreateUserAsync(newUsername, newPassword);
        statusMessage = $"User '{newUsername}' created";
        newUsername = "";
        newPassword = "";
        await RefreshAsync();
    }

    private void StartEdit(RelayUser user)
    {
        editingUser = user;
        editEnabled = user.IsEnabled.ToString().ToLowerInvariant();
        editAllowedSenders = user.AllowedSenderAddresses ?? "";
        editRatePerMinuteStr = user.RateLimitPerMinute?.ToString() ?? "";
        editRatePerDayStr = user.RateLimitPerDay?.ToString() ?? "";
        isEditDialogOpen = true;
    }

    private void CancelEdit()
    {
        isEditDialogOpen = false;
        editingUser = null;
    }

    private async Task SaveEditAsync()
    {
        if (editingUser is null) return;

        using var scope = ScopeFactory.CreateScope();
        var db = scope.ServiceProvider.GetRequiredService<RelayDbContext>();
        var user = await db.RelayUsers.FindAsync(editingUser.Id);
        if (user is null) return;

        user.IsEnabled = editEnabled == "true";
        user.AllowedSenderAddresses = string.IsNullOrWhiteSpace(editAllowedSenders) ? null : editAllowedSenders.Trim();
        user.RateLimitPerMinute = editRatePerMinute;
        user.RateLimitPerDay = editRatePerDay;
        await db.SaveChangesAsync();

        statusMessage = $"User '{user.Username}' updated";
        isEditDialogOpen = false;
        editingUser = null;
        await RefreshAsync();
    }

    private async Task ConfirmDeleteAsync()
    {
        await DeleteUserAsync(deleteTargetId);
        showDeleteConfirm = false;
    }

    private async Task DeleteUserAsync(int id)
    {
        using var scope = ScopeFactory.CreateScope();
        var svc = scope.ServiceProvider.GetRequiredService<IUserService>();
        await svc.DeleteUserAsync(id);
        statusMessage = "User deleted";
        isEditDialogOpen = false;
        editingUser = null;
        await RefreshAsync();
    }
}
