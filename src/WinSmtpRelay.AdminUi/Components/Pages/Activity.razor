@page "/activity"
@using Microsoft.AspNetCore.SignalR.Client
@inject NavigationManager Navigation
@implements IAsyncDisposable

<BbBreadcrumb>
    <BbBreadcrumbList>
        <BbBreadcrumbItem>
            <BbBreadcrumbLink Href="/">Home</BbBreadcrumbLink>
        </BbBreadcrumbItem>
        <BbBreadcrumbSeparator />
        <BbBreadcrumbItem>
            <BbBreadcrumbPage>Live Activity</BbBreadcrumbPage>
        </BbBreadcrumbItem>
    </BbBreadcrumbList>
</BbBreadcrumb>

<div class="page-header">
    <h1>Live Activity</h1>
    <p>Real-time feed of SMTP connections, messages, and deliveries</p>
</div>

<div style="margin-bottom:1rem;display:flex;align-items:center;gap:1rem;">
    <span class="badge-status @(isConnected ? "badge-success" : "badge-error")">
        @(isConnected ? "Connected" : "Disconnected")
    </span>
    <BbButton Size="ButtonSize.Small" Variant="ButtonVariant.Outline" @onclick="ClearFeed">
        <LucideIcon Name="eraser" />
        Clear
    </BbButton>
</div>

<div class="activity-feed">
    @if (events.Count == 0)
    {
        <p style="text-align:center;" class="text-muted">Waiting for activity...</p>
    }
    @foreach (var evt in events)
    {
        <div class="activity-item @evt.CssClass">
            <span class="activity-time">@evt.Timestamp.ToString("HH:mm:ss")</span>
            <span class="activity-icon">@evt.Icon</span>
            <span class="activity-text">@evt.Text</span>
        </div>
    }
</div>

@code {
    private HubConnection? hubConnection;
    private bool isConnected;
    private bool _disposed;
    private readonly List<ActivityEvent> events = [];
    private const int MaxEvents = 200;

    protected override async Task OnInitializedAsync()
    {
        var hubUrl = Navigation.ToAbsoluteUri("/hubs/activity");
        hubConnection = new HubConnectionBuilder()
            .WithUrl(hubUrl)
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On<dynamic>("MessageReceived", (data) =>
        {
            AddEvent(">>>", $"Message received from {data.GetProperty("sender")} to {data.GetProperty("recipients")} ({data.GetProperty("sizeBytes")} bytes)", "activity-received");
        });

        hubConnection.On<dynamic>("DeliveryAttempt", (data) =>
        {
            var status = data.GetProperty("statusCode").ToString();
            var cssClass = status == "250" ? "activity-delivered" : "activity-error";
            AddEvent("<<<", $"Delivery to {data.GetProperty("recipient")}: {status} via {data.GetProperty("remoteServer")}", cssClass);
        });

        hubConnection.On<dynamic>("SmtpConnection", (data) =>
        {
            AddEvent("...", $"SMTP {data.GetProperty("eventType")} from {data.GetProperty("sourceIp")}", "activity-connection");
        });

        hubConnection.Closed += _ => { isConnected = false; if (!_disposed) InvokeAsync(StateHasChanged); return Task.CompletedTask; };
        hubConnection.Reconnected += _ => { isConnected = true; if (!_disposed) InvokeAsync(StateHasChanged); return Task.CompletedTask; };

        try
        {
            await hubConnection.StartAsync();
            isConnected = true;
        }
        catch
        {
            isConnected = false;
        }
    }

    private void AddEvent(string icon, string text, string cssClass)
    {
        if (_disposed) return;
        events.Insert(0, new ActivityEvent(DateTime.Now, icon, text, cssClass));
        if (events.Count > MaxEvents)
            events.RemoveAt(events.Count - 1);
        InvokeAsync(StateHasChanged);
    }

    private void ClearFeed() => events.Clear();

    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        if (hubConnection is not null)
            await hubConnection.DisposeAsync();
    }

    private record ActivityEvent(DateTime Timestamp, string Icon, string Text, string CssClass);
}
