@page "/activity"
@using Microsoft.AspNetCore.SignalR.Client
@inject NavigationManager Navigation
@implements IAsyncDisposable

<BbBreadcrumb>
    <BbBreadcrumbList>
        <BbBreadcrumbItem>
            <BbBreadcrumbLink Href="/">Home</BbBreadcrumbLink>
        </BbBreadcrumbItem>
        <BbBreadcrumbSeparator />
        <BbBreadcrumbItem>
            <BbBreadcrumbPage>Live Activity</BbBreadcrumbPage>
        </BbBreadcrumbItem>
    </BbBreadcrumbList>
</BbBreadcrumb>

<div class="page-header page-header-row">
    <div>
        <h1>Live Activity</h1>
        <p>Real-time feed of SMTP connections, messages, and deliveries</p>
    </div>
    <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" @onclick="() => showHelp = true">
        <LucideIcon Name="info" /> About this page
    </BbButton>
</div>

<div style="margin-bottom:1rem;display:flex;align-items:center;gap:1rem;">
    <span class="badge-status @(isConnected ? "badge-success" : "badge-error")">
        @(isConnected ? "Connected" : "Disconnected")
    </span>
    <BbButton Size="ButtonSize.Small" Variant="ButtonVariant.Outline" @onclick="ClearFeed">
        <LucideIcon Name="eraser" />
        Clear
    </BbButton>
</div>

<div class="activity-feed">
    @if (events.Count == 0)
    {
        <p style="text-align:center;" class="text-muted">Waiting for activity...</p>
    }
    @foreach (var evt in events)
    {
        <div class="activity-item @evt.CssClass">
            <span class="activity-time">@evt.Timestamp.ToString("HH:mm:ss")</span>
            <span class="activity-icon">@evt.Icon</span>
            <span class="activity-text">@evt.Text</span>
        </div>
    }
</div>

<BbDialog @bind-Open="showHelp">
    <BbDialogContent>
        <BbDialogHeader>
            <BbDialogTitle>About Live Activity</BbDialogTitle>
            <BbDialogDescription>Real-time SMTP event monitoring</BbDialogDescription>
        </BbDialogHeader>
        <div style="font-size:0.875rem;line-height:1.6;">
            <p>
                This page shows a real-time feed of everything happening on the SMTP relay,
                streamed via SignalR (WebSocket).
            </p>
            <h4 style="margin-top:1rem;">Event types</h4>
            <ul style="padding-left:1.25rem;">
                <li><strong>&gt;&gt;&gt; Message Received</strong> &mdash; an application submitted an email to the relay. Shows sender, recipients, and size.</li>
                <li><strong>&lt;&lt;&lt; Delivery Attempt</strong> &mdash; the relay tried to deliver a message. Shows the SMTP status code (250 = success) and the remote server used.</li>
                <li><strong>... SMTP Connection</strong> &mdash; a client connected to or disconnected from the SMTP listener.</li>
            </ul>
            <h4 style="margin-top:1rem;">Connection status</h4>
            <p>
                The badge at the top shows whether the browser is connected to the server's SignalR hub.
                If disconnected, the feed will pause and automatically reconnect.
            </p>
            <p>
                The feed holds up to 200 events. Use <strong>Clear</strong> to reset.
            </p>
        </div>
        <BbDialogFooter>
            <BbDialogClose>
                <BbButton Variant="ButtonVariant.Outline">Close</BbButton>
            </BbDialogClose>
        </BbDialogFooter>
    </BbDialogContent>
</BbDialog>

@code {
    private bool showHelp;
    private HubConnection? hubConnection;
    private bool isConnected;
    private bool _disposed;
    private readonly List<ActivityEvent> events = [];
    private const int MaxEvents = 200;

    protected override async Task OnInitializedAsync()
    {
        var hubUrl = Navigation.ToAbsoluteUri("/hubs/activity");
        hubConnection = new HubConnectionBuilder()
            .WithUrl(hubUrl)
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On<dynamic>("MessageReceived", (data) =>
        {
            AddEvent(">>>", $"Message received from {data.GetProperty("sender")} to {data.GetProperty("recipients")} ({data.GetProperty("sizeBytes")} bytes)", "activity-received");
        });

        hubConnection.On<dynamic>("DeliveryAttempt", (data) =>
        {
            var status = data.GetProperty("statusCode").ToString();
            var cssClass = status == "250" ? "activity-delivered" : "activity-error";
            AddEvent("<<<", $"Delivery to {data.GetProperty("recipient")}: {status} via {data.GetProperty("remoteServer")}", cssClass);
        });

        hubConnection.On<dynamic>("SmtpConnection", (data) =>
        {
            AddEvent("...", $"SMTP {data.GetProperty("eventType")} from {data.GetProperty("sourceIp")}", "activity-connection");
        });

        hubConnection.Closed += _ => { isConnected = false; if (!_disposed) InvokeAsync(StateHasChanged); return Task.CompletedTask; };
        hubConnection.Reconnected += _ => { isConnected = true; if (!_disposed) InvokeAsync(StateHasChanged); return Task.CompletedTask; };

        try
        {
            await hubConnection.StartAsync();
            isConnected = true;
        }
        catch
        {
            isConnected = false;
        }
    }

    private void AddEvent(string icon, string text, string cssClass)
    {
        if (_disposed) return;
        events.Insert(0, new ActivityEvent(DateTime.Now, icon, text, cssClass));
        if (events.Count > MaxEvents)
            events.RemoveAt(events.Count - 1);
        InvokeAsync(StateHasChanged);
    }

    private void ClearFeed() => events.Clear();

    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        if (hubConnection is not null)
            await hubConnection.DisposeAsync();
    }

    private record ActivityEvent(DateTime Timestamp, string Icon, string Text, string CssClass);
}
