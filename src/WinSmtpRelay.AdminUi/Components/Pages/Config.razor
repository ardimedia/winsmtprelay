@page "/config"
@using Microsoft.Extensions.Options
@using System.Net
@using System.Net.NetworkInformation
@using System.Net.Sockets
@using WinSmtpRelay.Core.Configuration
@inject IOptions<SmtpListenerOptions> SmtpOptions
@inject IOptions<DeliveryOptions> DeliveryOpts
@inject IOptions<TlsOptions> TlsOpts
@inject IOptions<DkimOptions> DkimOpts
@inject IOptions<AdminUiOptions> AdminOpts
@inject IOptions<RateLimitOptions> RateLimitOpts
@inject IOptions<WebhookOptions> WebhookOpts
@inject IOptions<MessageFilterOptions> FilterOpts
@inject IOptions<BackupMxOptions> BackupMxOpts

<BbBreadcrumb>
    <BbBreadcrumbList>
        <BbBreadcrumbItem>
            <BbBreadcrumbLink Href="/">Home</BbBreadcrumbLink>
        </BbBreadcrumbItem>
        <BbBreadcrumbSeparator />
        <BbBreadcrumbItem>
            <BbBreadcrumbPage>Configuration</BbBreadcrumbPage>
        </BbBreadcrumbItem>
    </BbBreadcrumbList>
</BbBreadcrumb>

<div class="page-header">
    <h1>Configuration</h1>
    <p>Read-only view of appsettings.json. Edit the file and restart the service to apply changes.</p>
</div>

<BbTabs DefaultValue="listener" @bind-Value="activeConfigTab">
    <div class="tabs-bar">
        <BbTabsList>
            <BbTabsTrigger Value="listener">Listener</BbTabsTrigger>
            <BbTabsTrigger Value="delivery">Delivery</BbTabsTrigger>
            <BbTabsTrigger Value="security">Security</BbTabsTrigger>
            <BbTabsTrigger Value="advanced">Advanced</BbTabsTrigger>
        </BbTabsList>
        @if (activeConfigTab == "listener")
        {
            <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" @onclick="() => showListenerHelp = true">
                <LucideIcon Name="info" /> About Listener
            </BbButton>
        }
        else if (activeConfigTab == "delivery")
        {
            <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" @onclick="() => showDeliveryHelp = true">
                <LucideIcon Name="info" /> About Delivery
            </BbButton>
        }
        else if (activeConfigTab == "security")
        {
            <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" @onclick="() => showSecurityHelp = true">
                <LucideIcon Name="info" /> About Security
            </BbButton>
        }
        else if (activeConfigTab == "advanced")
        {
            <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" @onclick="() => showAdvancedHelp = true">
                <LucideIcon Name="info" /> About Advanced
            </BbButton>
        }
    </div>

    <BbTabsContent Value="listener">
        <BbCard Class="mb-1">
            <BbCardHeader><BbCardTitle>SMTP Listener</BbCardTitle></BbCardHeader>
            <BbCardContent>
                <table>
                    <thead>
                        <tr>
                            <th>Address</th>
                            <th>Port</th>
                            <th>TLS</th>
                            <th>Implicit TLS</th>
                            <th>Auth Required</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var ep in SmtpOptions.Value.Endpoints)
                        {
                            <tr>
                                <td class="mono">@ep.Address</td>
                                <td class="mono">@ep.Port</td>
                                <td>@ep.RequireTls</td>
                                <td>@ep.ImplicitTls</td>
                                <td>@ep.RequireAuth</td>
                            </tr>
                        }
                    </tbody>
                </table>
                <table class="mt-1 kv-table">
                    <tbody>
                        <tr>
                            <td class="text-muted">Max message size</td>
                            <td>@(SmtpOptions.Value.MaxMessageSizeBytes / 1024 / 1024) MB</td>
                        </tr>
                        <tr>
                            <td class="text-muted">Max connections</td>
                            <td>@SmtpOptions.Value.MaxConnections</td>
                        </tr>
                        <tr>
                            <td class="text-muted">Allowed networks</td>
                            <td>@string.Join(", ", SmtpOptions.Value.AllowedNetworks)</td>
                        </tr>
                        @if (!string.IsNullOrWhiteSpace(SmtpOptions.Value.PickupFolder))
                        {
                            <tr>
                                <td class="text-muted">Pickup folder</td>
                                <td>@SmtpOptions.Value.PickupFolder (poll every @SmtpOptions.Value.PickupFolderPollIntervalSeconds s)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </BbCardContent>
        </BbCard>
    </BbTabsContent>

    <BbTabsContent Value="delivery">
        <BbCard Class="mb-1">
            <BbCardHeader><BbCardTitle>Delivery</BbCardTitle></BbCardHeader>
            <BbCardContent>
                <div>
                    <span class="text-muted">Concurrent deliveries:</span> @DeliveryOpts.Value.MaxConcurrentDeliveries |
                    <span class="text-muted">Max retry:</span> @DeliveryOpts.Value.MaxRetryHours h |
                    <span class="text-muted">Opportunistic TLS:</span> @DeliveryOpts.Value.OpportunisticTls
                </div>
                @if (!string.IsNullOrWhiteSpace(DeliveryOpts.Value.SmartHost))
                {
                    <div class="mt-1">
                        <span class="text-muted">Smart host:</span> @DeliveryOpts.Value.SmartHost:@DeliveryOpts.Value.SmartHostPort
                    </div>
                }
                <div class="mt-1 text-muted" style="font-size:0.8rem">
                    Retry intervals: @string.Join(", ", DeliveryOpts.Value.RetryIntervalsMinutes.Select(m => $"{m}m"))
                </div>
            </BbCardContent>
        </BbCard>

        @if (DeliveryOpts.Value.DomainRoutes.Count > 0)
        {
            <BbCard Class="mb-1">
                <BbCardHeader><BbCardTitle>Domain Routes</BbCardTitle></BbCardHeader>
                <BbCardContent>
                    <table>
                        <thead>
                            <tr>
                                <th>Domain Pattern</th>
                                <th>Host</th>
                                <th>Port</th>
                                <th>Auth</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var route in DeliveryOpts.Value.DomainRoutes)
                            {
                                <tr>
                                    <td class="mono">@route.DomainPattern</td>
                                    <td class="mono">@route.Host</td>
                                    <td class="mono">@route.Port</td>
                                    <td>@(!string.IsNullOrWhiteSpace(route.Username) ? "Yes" : "No")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </BbCardContent>
            </BbCard>
        }
    </BbTabsContent>

    <BbTabsContent Value="security">
        <BbCard Class="mb-1">
            <BbCardHeader><BbCardTitle>TLS</BbCardTitle></BbCardHeader>
            <BbCardContent>
                @if (!string.IsNullOrWhiteSpace(TlsOpts.Value.CertificatePath))
                {
                    <div><span class="text-muted">Certificate:</span> PFX file configured</div>
                }
                else if (!string.IsNullOrWhiteSpace(TlsOpts.Value.CertificateThumbprint))
                {
                    <div><span class="text-muted">Certificate:</span> Store thumbprint @TlsOpts.Value.CertificateThumbprint[..8]...</div>
                }
                else
                {
                    <div class="text-muted">No TLS certificate configured</div>
                }
            </BbCardContent>
        </BbCard>

        <BbCard Class="mb-1">
            <BbCardHeader><BbCardTitle>DKIM</BbCardTitle></BbCardHeader>
            <BbCardContent>
                <div><span class="text-muted">Enabled:</span> @DkimOpts.Value.Enabled</div>
                @if (DkimOpts.Value.Enabled && DkimOpts.Value.Domains.Count > 0)
                {
                    <div class="mt-1">
                        @foreach (var d in DkimOpts.Value.Domains)
                        {
                            <div>@d.Domain (selector: @d.Selector)</div>
                        }
                    </div>
                }
            </BbCardContent>
        </BbCard>

        <BbCard Class="mb-1">
            <BbCardHeader><BbCardTitle>Rate Limiting</BbCardTitle></BbCardHeader>
            <BbCardContent>
                <div>
                    <span class="text-muted">Per-IP:</span> @RateLimitOpts.Value.MaxConnectionsPerIpPerMinute /min |
                    <span class="text-muted">Per-sender:</span> @RateLimitOpts.Value.MaxMessagesPerSenderPerMinute /min, @RateLimitOpts.Value.MaxMessagesPerSenderPerDay /day
                </div>
                <div class="mt-1">
                    <span class="text-muted">Failed auth ban:</span> after @RateLimitOpts.Value.FailedAuthBanThreshold attempts, ban for @RateLimitOpts.Value.FailedAuthBanMinutes min
                </div>
            </BbCardContent>
        </BbCard>
    </BbTabsContent>

    <BbTabsContent Value="advanced">
        @if (FilterOpts.Value.HeaderRewrites.Count > 0 || FilterOpts.Value.SenderRewrites.Count > 0)
        {
            <BbCard Class="mb-1">
                <BbCardHeader><BbCardTitle>Message Filters</BbCardTitle></BbCardHeader>
                <BbCardContent>
                    @if (FilterOpts.Value.HeaderRewrites.Count > 0)
                    {
                        <div class="mb-1">
                            <strong style="font-size:0.85rem">Header Rewrites</strong>
                            <table>
                                <thead>
                                    <tr>
                                        <th>Header</th>
                                        <th>Action</th>
                                        <th>Match</th>
                                        <th>Value</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var rule in FilterOpts.Value.HeaderRewrites)
                                    {
                                        <tr>
                                            <td class="mono">@rule.HeaderName</td>
                                            <td>@rule.Action</td>
                                            <td class="mono">@(rule.MatchValue ?? "—")</td>
                                            <td class="mono">@(rule.NewValue ?? "—")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    @if (FilterOpts.Value.SenderRewrites.Count > 0)
                    {
                        <div>
                            <strong style="font-size:0.85rem">Sender Rewrites</strong>
                            <table>
                                <thead>
                                    <tr>
                                        <th>From Pattern</th>
                                        <th>To Address</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var rule in FilterOpts.Value.SenderRewrites)
                                    {
                                        <tr>
                                            <td class="mono">@rule.FromPattern</td>
                                            <td class="mono">@rule.ToAddress</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </BbCardContent>
            </BbCard>
        }

        @if (WebhookOpts.Value.OnMessageReceived.Count > 0)
        {
            <BbCard Class="mb-1">
                <BbCardHeader><BbCardTitle>Webhooks</BbCardTitle></BbCardHeader>
                <BbCardContent>
                    <table>
                        <thead>
                            <tr>
                                <th>Event</th>
                                <th>URL</th>
                                <th>Timeout</th>
                                <th>Signed</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var wh in WebhookOpts.Value.OnMessageReceived)
                            {
                                <tr>
                                    <td>message.received</td>
                                    <td class="mono">@wh.Url</td>
                                    <td>@wh.TimeoutSeconds s</td>
                                    <td>@(!string.IsNullOrWhiteSpace(wh.Secret) ? "Yes" : "No")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </BbCardContent>
            </BbCard>
        }

        @if (BackupMxOpts.Value.Enabled)
        {
            <BbCard Class="mb-1">
                <BbCardHeader><BbCardTitle>Backup MX</BbCardTitle></BbCardHeader>
                <BbCardContent>
                    <div>
                        <span class="text-muted">Domains:</span> @string.Join(", ", BackupMxOpts.Value.Domains)
                    </div>
                    <div class="mt-1">
                        <span class="text-muted">Retry interval:</span> @BackupMxOpts.Value.RetryIntervalMinutes min |
                        <span class="text-muted">Max hold:</span> @BackupMxOpts.Value.MaxHoldHours h (@(BackupMxOpts.Value.MaxHoldHours / 24) days)
                    </div>
                </BbCardContent>
            </BbCard>
        }

        <BbCard>
            <BbCardHeader><BbCardTitle>Admin UI</BbCardTitle></BbCardHeader>
            <BbCardContent>
                <div>
                    <span class="text-muted">Bind:</span> @AdminOpts.Value.BindAddress:@AdminOpts.Value.Port
                </div>
                <div class="mt-1">
                    <span class="text-muted">Reachable at:</span>
                    @foreach (var url in GetReachableUrls())
                    {
                        <span class="mono" style="margin-right:1rem;">@url</span>
                    }
                </div>
            </BbCardContent>
        </BbCard>
    </BbTabsContent>
</BbTabs>

<BbDialog @bind-Open="showListenerHelp">
    <BbDialogContent>
        <BbDialogHeader>
            <BbDialogTitle>About Listener</BbDialogTitle>
            <BbDialogDescription>Understanding the SMTP listener settings</BbDialogDescription>
        </BbDialogHeader>
        <div style="font-size:0.875rem;line-height:1.6;">
            <p>
                The Listener tab configures how WinSmtpRelay accepts incoming SMTP connections.
            </p>
            <h4 style="margin-top:1rem;">SMTP Endpoints</h4>
            <p>
                Each endpoint defines a combination of bind address, port, TLS mode (off, STARTTLS, or implicit TLS),
                and whether authentication is required. Common setups use port 25 for server-to-server relay and
                port 587 for authenticated submission.
            </p>
            <h4 style="margin-top:1rem;">Connection limits</h4>
            <ul style="padding-left:1.25rem;">
                <li><strong>Max message size</strong> &mdash; rejects messages larger than this limit during the SMTP DATA phase.</li>
                <li><strong>Max connections</strong> &mdash; total concurrent SMTP connections allowed before new connections are refused.</li>
                <li><strong>Allowed networks</strong> &mdash; CIDR ranges permitted to relay without authentication (e.g., internal subnets).</li>
            </ul>
            <h4 style="margin-top:1rem;">Pickup folder</h4>
            <p>
                When configured, the relay monitors a directory for <code>.eml</code> files and queues them for delivery.
                Useful for applications that write email files to disk instead of speaking SMTP.
            </p>
        </div>
        <BbDialogFooter>
            <BbDialogClose>
                <BbButton Variant="ButtonVariant.Outline">Close</BbButton>
            </BbDialogClose>
        </BbDialogFooter>
    </BbDialogContent>
</BbDialog>

<BbDialog @bind-Open="showDeliveryHelp">
    <BbDialogContent>
        <BbDialogHeader>
            <BbDialogTitle>About Delivery</BbDialogTitle>
            <BbDialogDescription>Understanding the outbound delivery settings</BbDialogDescription>
        </BbDialogHeader>
        <div style="font-size:0.875rem;line-height:1.6;">
            <p>
                The Delivery tab controls how WinSmtpRelay sends messages to their destination.
            </p>
            <h4 style="margin-top:1rem;">Delivery settings</h4>
            <ul style="padding-left:1.25rem;">
                <li><strong>Concurrent deliveries</strong> &mdash; maximum number of messages sent simultaneously.</li>
                <li><strong>Max retry</strong> &mdash; how long a message stays in the queue before being bounced as undeliverable.</li>
                <li><strong>Retry intervals</strong> &mdash; the delay between each delivery attempt (e.g., 1m, 5m, 15m, 60m).</li>
                <li><strong>Opportunistic TLS</strong> &mdash; when enabled, the relay upgrades to TLS if the remote server supports STARTTLS.</li>
            </ul>
            <h4 style="margin-top:1rem;">Smart host</h4>
            <p>
                Routes all outbound mail through a single upstream server instead of delivering directly via MX lookup.
                Common when your network blocks outbound port 25.
            </p>
            <h4 style="margin-top:1rem;">Domain routes</h4>
            <p>
                Per-domain overrides that route specific recipient domains to a designated host, bypassing the default
                smart host or MX delivery path.
            </p>
        </div>
        <BbDialogFooter>
            <BbDialogClose>
                <BbButton Variant="ButtonVariant.Outline">Close</BbButton>
            </BbDialogClose>
        </BbDialogFooter>
    </BbDialogContent>
</BbDialog>

<BbDialog @bind-Open="showSecurityHelp">
    <BbDialogContent>
        <BbDialogHeader>
            <BbDialogTitle>About Security</BbDialogTitle>
            <BbDialogDescription>Understanding the security settings</BbDialogDescription>
        </BbDialogHeader>
        <div style="font-size:0.875rem;line-height:1.6;">
            <p>
                The Security tab covers encryption, email authentication, and abuse prevention.
            </p>
            <h4 style="margin-top:1rem;">TLS</h4>
            <p>
                Configure the server certificate used for STARTTLS and implicit TLS connections. You can provide
                a PFX file path or reference a certificate by thumbprint from the Windows certificate store.
            </p>
            <h4 style="margin-top:1rem;">DKIM</h4>
            <p>
                DomainKeys Identified Mail signs outbound messages with a cryptographic signature, allowing receiving
                servers to verify the message was sent by an authorized sender for the domain.
            </p>
            <h4 style="margin-top:1rem;">Rate limiting</h4>
            <ul style="padding-left:1.25rem;">
                <li><strong>Per-IP</strong> &mdash; limits connections per minute from a single IP address.</li>
                <li><strong>Per-sender</strong> &mdash; limits messages per minute and per day from a single envelope sender.</li>
                <li><strong>Failed auth ban</strong> &mdash; temporarily bans an IP after repeated authentication failures.</li>
            </ul>
        </div>
        <BbDialogFooter>
            <BbDialogClose>
                <BbButton Variant="ButtonVariant.Outline">Close</BbButton>
            </BbDialogClose>
        </BbDialogFooter>
    </BbDialogContent>
</BbDialog>

<BbDialog @bind-Open="showAdvancedHelp">
    <BbDialogContent>
        <BbDialogHeader>
            <BbDialogTitle>About Advanced</BbDialogTitle>
            <BbDialogDescription>Understanding the advanced settings</BbDialogDescription>
        </BbDialogHeader>
        <div style="font-size:0.875rem;line-height:1.6;">
            <p>
                The Advanced tab contains specialized settings for message processing, integrations, and infrastructure.
            </p>
            <h4 style="margin-top:1rem;">Message filters</h4>
            <p>
                Header rewrites can add, remove, or modify email headers before delivery. Sender rewrites change the
                envelope sender address based on pattern matching &mdash; useful for masking internal addresses.
            </p>
            <h4 style="margin-top:1rem;">Webhooks</h4>
            <p>
                HTTP callbacks triggered on events like message receipt. Can be signed with a shared secret for
                verification. Useful for integrating with ticketing systems, chat platforms, or custom workflows.
            </p>
            <h4 style="margin-top:1rem;">Backup MX</h4>
            <p>
                When enabled, WinSmtpRelay acts as a secondary mail exchanger for the listed domains, holding messages
                and retrying delivery to the primary server.
            </p>
            <h4 style="margin-top:1rem;">Admin UI</h4>
            <p>
                The bind address and port for this web interface (default: <code>0.0.0.0:8025</code>).
            </p>
        </div>
        <BbDialogFooter>
            <BbDialogClose>
                <BbButton Variant="ButtonVariant.Outline">Close</BbButton>
            </BbDialogClose>
        </BbDialogFooter>
    </BbDialogContent>
</BbDialog>

@code {
    private string activeConfigTab = "listener";
    private bool showListenerHelp;
    private bool showDeliveryHelp;
    private bool showSecurityHelp;
    private bool showAdvancedHelp;

    private List<string> GetReachableUrls()
    {
        var bind = AdminOpts.Value.BindAddress;
        var port = AdminOpts.Value.Port;
        var urls = new List<string>();

        if (bind is "0.0.0.0" or "::" or "*")
        {
            urls.Add($"http://localhost:{port}");
            foreach (var ni in NetworkInterface.GetAllNetworkInterfaces())
            {
                if (ni.OperationalStatus != OperationalStatus.Up)
                    continue;
                foreach (var addr in ni.GetIPProperties().UnicastAddresses)
                {
                    if (addr.Address.AddressFamily == AddressFamily.InterNetwork
                        && !IPAddress.IsLoopback(addr.Address))
                    {
                        urls.Add($"http://{addr.Address}:{port}");
                    }
                }
            }
        }
        else
        {
            urls.Add($"http://{bind}:{port}");
        }

        return urls;
    }
}
