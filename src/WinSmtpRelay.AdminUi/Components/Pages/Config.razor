@page "/config"
@using Microsoft.Extensions.Options
@using WinSmtpRelay.Core.Configuration
@inject IOptions<SmtpListenerOptions> SmtpOptions
@inject IOptions<DeliveryOptions> DeliveryOpts
@inject IOptions<TlsOptions> TlsOpts
@inject IOptions<DkimOptions> DkimOpts
@inject IOptions<AdminUiOptions> AdminOpts
@inject IOptions<RateLimitOptions> RateLimitOpts
@inject IOptions<WebhookOptions> WebhookOpts
@inject IOptions<MessageFilterOptions> FilterOpts
@inject IOptions<BackupMxOptions> BackupMxOpts

<BbBreadcrumb>
    <BbBreadcrumbList>
        <BbBreadcrumbItem>
            <BbBreadcrumbLink Href="/">Home</BbBreadcrumbLink>
        </BbBreadcrumbItem>
        <BbBreadcrumbSeparator />
        <BbBreadcrumbItem>
            <BbBreadcrumbPage>Configuration</BbBreadcrumbPage>
        </BbBreadcrumbItem>
    </BbBreadcrumbList>
</BbBreadcrumb>

<div class="page-header page-header-row">
    <div>
        <h1>Configuration</h1>
        <p>Read-only view of appsettings.json. Edit the file and restart the service to apply changes.</p>
    </div>
    <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" @onclick="() => showHelp = true">
        <LucideIcon Name="info" /> About this page
    </BbButton>
</div>

<BbDialog @bind-Open="showHelp">
    <BbDialogContent>
        <BbDialogHeader>
            <BbDialogTitle>About Configuration</BbDialogTitle>
            <BbDialogDescription>Understanding the relay settings</BbDialogDescription>
        </BbDialogHeader>
        <div style="font-size:0.875rem;line-height:1.6;">
            <p>
                This page shows a <strong>read-only</strong> view of the current WinSmtpRelay configuration,
                loaded from <code>appsettings.json</code>. To change settings, edit the file directly and
                restart the Windows service.
            </p>
            <h4 style="margin-top:1rem;">Configuration tabs</h4>
            <ul style="padding-left:1.25rem;">
                <li><strong>Listener</strong> &mdash; SMTP endpoints (addresses, ports, TLS mode, authentication), max message size, allowed networks, and the optional pickup folder for file-based message submission.</li>
                <li><strong>Delivery</strong> &mdash; outbound settings: smart host, concurrent delivery limit, retry intervals, max retry window, opportunistic TLS, and per-domain routing rules.</li>
                <li><strong>Security</strong> &mdash; TLS certificate configuration, DKIM signing domains, and rate-limiting thresholds (per-IP connections, per-sender messages, failed-auth banning).</li>
                <li><strong>Advanced</strong> &mdash; message filter rules (header/sender rewrites), webhook endpoints, backup MX settings, and Admin UI bind address.</li>
            </ul>
            <h4 style="margin-top:1rem;">Configuration file</h4>
            <p>
                The configuration file is located alongside the service executable, typically at
                <code>C:\Program Files\WinSmtpRelay\appsettings.json</code>. Changes require a service restart
                to take effect.
            </p>
        </div>
        <BbDialogFooter>
            <BbDialogClose>
                <BbButton Variant="ButtonVariant.Outline">Close</BbButton>
            </BbDialogClose>
        </BbDialogFooter>
    </BbDialogContent>
</BbDialog>

<BbTabs DefaultValue="listener">
    <BbTabsList>
        <BbTabsTrigger Value="listener">Listener</BbTabsTrigger>
        <BbTabsTrigger Value="delivery">Delivery</BbTabsTrigger>
        <BbTabsTrigger Value="security">Security</BbTabsTrigger>
        <BbTabsTrigger Value="advanced">Advanced</BbTabsTrigger>
    </BbTabsList>

    <BbTabsContent Value="listener">
        <BbCard Class="mb-1">
            <BbCardHeader><BbCardTitle>SMTP Listener</BbCardTitle></BbCardHeader>
            <BbCardContent>
                <table>
                    <thead>
                        <tr>
                            <th>Address</th>
                            <th>Port</th>
                            <th>TLS</th>
                            <th>Implicit TLS</th>
                            <th>Auth Required</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var ep in SmtpOptions.Value.Endpoints)
                        {
                            <tr>
                                <td class="mono">@ep.Address</td>
                                <td class="mono">@ep.Port</td>
                                <td>@ep.RequireTls</td>
                                <td>@ep.ImplicitTls</td>
                                <td>@ep.RequireAuth</td>
                            </tr>
                        }
                    </tbody>
                </table>
                <div class="mt-1">
                    <span class="text-muted">Max message size:</span> @(SmtpOptions.Value.MaxMessageSizeBytes / 1024 / 1024) MB |
                    <span class="text-muted">Max connections:</span> @SmtpOptions.Value.MaxConnections |
                    <span class="text-muted">Allowed networks:</span> @string.Join(", ", SmtpOptions.Value.AllowedNetworks)
                </div>
                @if (!string.IsNullOrWhiteSpace(SmtpOptions.Value.PickupFolder))
                {
                    <div class="mt-1">
                        <span class="text-muted">Pickup folder:</span> @SmtpOptions.Value.PickupFolder
                        (poll every @SmtpOptions.Value.PickupFolderPollIntervalSeconds s)
                    </div>
                }
            </BbCardContent>
        </BbCard>
    </BbTabsContent>

    <BbTabsContent Value="delivery">
        <BbCard Class="mb-1">
            <BbCardHeader><BbCardTitle>Delivery</BbCardTitle></BbCardHeader>
            <BbCardContent>
                <div>
                    <span class="text-muted">Concurrent deliveries:</span> @DeliveryOpts.Value.MaxConcurrentDeliveries |
                    <span class="text-muted">Max retry:</span> @DeliveryOpts.Value.MaxRetryHours h |
                    <span class="text-muted">Opportunistic TLS:</span> @DeliveryOpts.Value.OpportunisticTls
                </div>
                @if (!string.IsNullOrWhiteSpace(DeliveryOpts.Value.SmartHost))
                {
                    <div class="mt-1">
                        <span class="text-muted">Smart host:</span> @DeliveryOpts.Value.SmartHost:@DeliveryOpts.Value.SmartHostPort
                    </div>
                }
                <div class="mt-1 text-muted" style="font-size:0.8rem">
                    Retry intervals: @string.Join(", ", DeliveryOpts.Value.RetryIntervalsMinutes.Select(m => $"{m}m"))
                </div>
            </BbCardContent>
        </BbCard>

        @if (DeliveryOpts.Value.DomainRoutes.Count > 0)
        {
            <BbCard Class="mb-1">
                <BbCardHeader><BbCardTitle>Domain Routes</BbCardTitle></BbCardHeader>
                <BbCardContent>
                    <table>
                        <thead>
                            <tr>
                                <th>Domain Pattern</th>
                                <th>Host</th>
                                <th>Port</th>
                                <th>Auth</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var route in DeliveryOpts.Value.DomainRoutes)
                            {
                                <tr>
                                    <td class="mono">@route.DomainPattern</td>
                                    <td class="mono">@route.Host</td>
                                    <td class="mono">@route.Port</td>
                                    <td>@(!string.IsNullOrWhiteSpace(route.Username) ? "Yes" : "No")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </BbCardContent>
            </BbCard>
        }
    </BbTabsContent>

    <BbTabsContent Value="security">
        <BbCard Class="mb-1">
            <BbCardHeader><BbCardTitle>TLS</BbCardTitle></BbCardHeader>
            <BbCardContent>
                @if (!string.IsNullOrWhiteSpace(TlsOpts.Value.CertificatePath))
                {
                    <div><span class="text-muted">Certificate:</span> PFX file configured</div>
                }
                else if (!string.IsNullOrWhiteSpace(TlsOpts.Value.CertificateThumbprint))
                {
                    <div><span class="text-muted">Certificate:</span> Store thumbprint @TlsOpts.Value.CertificateThumbprint[..8]...</div>
                }
                else
                {
                    <div class="text-muted">No TLS certificate configured</div>
                }
            </BbCardContent>
        </BbCard>

        <BbCard Class="mb-1">
            <BbCardHeader><BbCardTitle>DKIM</BbCardTitle></BbCardHeader>
            <BbCardContent>
                <div><span class="text-muted">Enabled:</span> @DkimOpts.Value.Enabled</div>
                @if (DkimOpts.Value.Enabled && DkimOpts.Value.Domains.Count > 0)
                {
                    <div class="mt-1">
                        @foreach (var d in DkimOpts.Value.Domains)
                        {
                            <div>@d.Domain (selector: @d.Selector)</div>
                        }
                    </div>
                }
            </BbCardContent>
        </BbCard>

        <BbCard Class="mb-1">
            <BbCardHeader><BbCardTitle>Rate Limiting</BbCardTitle></BbCardHeader>
            <BbCardContent>
                <div>
                    <span class="text-muted">Per-IP:</span> @RateLimitOpts.Value.MaxConnectionsPerIpPerMinute /min |
                    <span class="text-muted">Per-sender:</span> @RateLimitOpts.Value.MaxMessagesPerSenderPerMinute /min, @RateLimitOpts.Value.MaxMessagesPerSenderPerDay /day
                </div>
                <div class="mt-1">
                    <span class="text-muted">Failed auth ban:</span> after @RateLimitOpts.Value.FailedAuthBanThreshold attempts, ban for @RateLimitOpts.Value.FailedAuthBanMinutes min
                </div>
            </BbCardContent>
        </BbCard>
    </BbTabsContent>

    <BbTabsContent Value="advanced">
        @if (FilterOpts.Value.HeaderRewrites.Count > 0 || FilterOpts.Value.SenderRewrites.Count > 0)
        {
            <BbCard Class="mb-1">
                <BbCardHeader><BbCardTitle>Message Filters</BbCardTitle></BbCardHeader>
                <BbCardContent>
                    @if (FilterOpts.Value.HeaderRewrites.Count > 0)
                    {
                        <div class="mb-1">
                            <strong style="font-size:0.85rem">Header Rewrites</strong>
                            <table>
                                <thead>
                                    <tr>
                                        <th>Header</th>
                                        <th>Action</th>
                                        <th>Match</th>
                                        <th>Value</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var rule in FilterOpts.Value.HeaderRewrites)
                                    {
                                        <tr>
                                            <td class="mono">@rule.HeaderName</td>
                                            <td>@rule.Action</td>
                                            <td class="mono">@(rule.MatchValue ?? "—")</td>
                                            <td class="mono">@(rule.NewValue ?? "—")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    @if (FilterOpts.Value.SenderRewrites.Count > 0)
                    {
                        <div>
                            <strong style="font-size:0.85rem">Sender Rewrites</strong>
                            <table>
                                <thead>
                                    <tr>
                                        <th>From Pattern</th>
                                        <th>To Address</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var rule in FilterOpts.Value.SenderRewrites)
                                    {
                                        <tr>
                                            <td class="mono">@rule.FromPattern</td>
                                            <td class="mono">@rule.ToAddress</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </BbCardContent>
            </BbCard>
        }

        @if (WebhookOpts.Value.OnMessageReceived.Count > 0)
        {
            <BbCard Class="mb-1">
                <BbCardHeader><BbCardTitle>Webhooks</BbCardTitle></BbCardHeader>
                <BbCardContent>
                    <table>
                        <thead>
                            <tr>
                                <th>Event</th>
                                <th>URL</th>
                                <th>Timeout</th>
                                <th>Signed</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var wh in WebhookOpts.Value.OnMessageReceived)
                            {
                                <tr>
                                    <td>message.received</td>
                                    <td class="mono">@wh.Url</td>
                                    <td>@wh.TimeoutSeconds s</td>
                                    <td>@(!string.IsNullOrWhiteSpace(wh.Secret) ? "Yes" : "No")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </BbCardContent>
            </BbCard>
        }

        @if (BackupMxOpts.Value.Enabled)
        {
            <BbCard Class="mb-1">
                <BbCardHeader><BbCardTitle>Backup MX</BbCardTitle></BbCardHeader>
                <BbCardContent>
                    <div>
                        <span class="text-muted">Domains:</span> @string.Join(", ", BackupMxOpts.Value.Domains)
                    </div>
                    <div class="mt-1">
                        <span class="text-muted">Retry interval:</span> @BackupMxOpts.Value.RetryIntervalMinutes min |
                        <span class="text-muted">Max hold:</span> @BackupMxOpts.Value.MaxHoldHours h (@(BackupMxOpts.Value.MaxHoldHours / 24) days)
                    </div>
                </BbCardContent>
            </BbCard>
        }

        <BbCard>
            <BbCardHeader><BbCardTitle>Admin UI</BbCardTitle></BbCardHeader>
            <BbCardContent>
                <div>
                    <span class="text-muted">Bind:</span> @AdminOpts.Value.BindAddress:@AdminOpts.Value.Port
                </div>
            </BbCardContent>
        </BbCard>
    </BbTabsContent>
</BbTabs>

@code {
    private bool showHelp;
}
