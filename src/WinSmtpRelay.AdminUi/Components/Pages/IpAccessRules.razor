@page "/ip-rules"
@using WinSmtpRelay.Core.Interfaces
@using WinSmtpRelay.Core.Models
@inject IServiceScopeFactory ScopeFactory

<BbBreadcrumb>
    <BbBreadcrumbList>
        <BbBreadcrumbItem>
            <BbBreadcrumbLink Href="/">Home</BbBreadcrumbLink>
        </BbBreadcrumbItem>
        <BbBreadcrumbSeparator />
        <BbBreadcrumbItem>
            <BbBreadcrumbPage>IP Access Rules</BbBreadcrumbPage>
        </BbBreadcrumbItem>
    </BbBreadcrumbList>
</BbBreadcrumb>

<div class="page-header page-header-row">
    <div>
        <h1>IP Access Rules</h1>
        <p>Network-level allow and deny rules, evaluated in sort order</p>
    </div>
    <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" @onclick="() => showHelp = true">
        <LucideIcon Name="info" /> About IP Rules
    </BbButton>
</div>

<div style="max-width:500px;">
<BbCard Class="mb-1">
    <BbCardHeader>
        <BbCardTitle>Add Rule</BbCardTitle>
    </BbCardHeader>
    <BbCardContent>
        <div class="form-group">
            <BbLabel>Network (CIDR)</BbLabel>
            <BbInput @bind-Value="newNetwork" Placeholder="10.0.0.0/8" />
        </div>
        <div class="form-group">
            <BbLabel>Action</BbLabel>
            <BbNativeSelect @bind-Value="newAction">
                <option value="Allow">Allow</option>
                <option value="Deny">Deny</option>
            </BbNativeSelect>
        </div>
        <div class="form-group">
            <BbLabel>Description (optional)</BbLabel>
            <BbInput @bind-Value="newDescription" Placeholder="Internal network" />
        </div>
    </BbCardContent>
    <BbCardFooter>
        <BbButton Variant="ButtonVariant.Default" @onclick="CreateAsync"
                Disabled="@string.IsNullOrWhiteSpace(newNetwork)">
            <LucideIcon Name="plus" /> Add
        </BbButton>
        @if (!string.IsNullOrEmpty(statusMessage))
        {
            <span class="text-muted" style="margin-left:1rem">@statusMessage</span>
        }
    </BbCardFooter>
</BbCard>
</div>

@if (isLoading)
{
    <BbSkeleton Class="h-[300px] w-full" />
}
else
{
    <BbTable Data="@rules">
        <BbTableHeader>
            <BbTableRow TData="IpAccessRule">
                <BbTableHeaderCell TData="IpAccessRule">Order</BbTableHeaderCell>
                <BbTableHeaderCell TData="IpAccessRule">Network</BbTableHeaderCell>
                <BbTableHeaderCell TData="IpAccessRule">Action</BbTableHeaderCell>
                <BbTableHeaderCell TData="IpAccessRule">Description</BbTableHeaderCell>
                <BbTableHeaderCell TData="IpAccessRule">Actions</BbTableHeaderCell>
            </BbTableRow>
        </BbTableHeader>
        <BbTableBody>
            @if (rules.Count == 0)
            {
                <BbTableRow TData="IpAccessRule">
                    <BbTableCell colspan="5" style="text-align:center;">No IP rules configured &mdash; all connections accepted</BbTableCell>
                </BbTableRow>
            }
            @foreach (var rule in rules)
            {
                <BbTableRow Item="@rule">
                    <BbTableCell>@rule.SortOrder</BbTableCell>
                    <BbTableCell><code>@rule.Network</code></BbTableCell>
                    <BbTableCell>
                        <span class="badge-status @(rule.Action == IpAccessAction.Allow ? "badge-success" : "badge-destructive")">
                            @rule.Action
                        </span>
                    </BbTableCell>
                    <BbTableCell>@(rule.Description ?? "\u2014")</BbTableCell>
                    <BbTableCell>
                        <BbDropdownMenu>
                            <BbDropdownMenuTrigger>
                                <BbButton Size="ButtonSize.Small" Variant="ButtonVariant.Ghost">
                                    <LucideIcon Name="ellipsis" />
                                </BbButton>
                            </BbDropdownMenuTrigger>
                            <BbDropdownMenuContent>
                                <BbDropdownMenuItem @onclick="() => StartEdit(rule)">
                                    <LucideIcon Name="pencil" /> Edit
                                </BbDropdownMenuItem>
                                <BbDropdownMenuSeparator />
                                <BbDropdownMenuItem @onclick="() => { deleteTargetId = rule.Id; showDeleteConfirm = true; }">
                                    <LucideIcon Name="trash-2" /> Delete
                                </BbDropdownMenuItem>
                            </BbDropdownMenuContent>
                        </BbDropdownMenu>
                    </BbTableCell>
                </BbTableRow>
            }
        </BbTableBody>
    </BbTable>
}

<BbDialog @bind-Open="isEditOpen">
    <BbDialogContent>
        <BbDialogHeader>
            <BbDialogTitle>Edit IP Rule</BbDialogTitle>
            <BbDialogDescription>Modify the IP access rule</BbDialogDescription>
        </BbDialogHeader>
        <div class="form-group">
            <BbLabel>Network (CIDR)</BbLabel>
            <BbInput @bind-Value="editNetwork" />
        </div>
        <div class="form-group">
            <BbLabel>Action</BbLabel>
            <BbNativeSelect @bind-Value="editAction">
                <option value="Allow">Allow</option>
                <option value="Deny">Deny</option>
            </BbNativeSelect>
        </div>
        <div class="form-group">
            <BbLabel>Sort Order</BbLabel>
            <BbInput Type="InputType.Number" @bind-Value="editSortOrder" />
        </div>
        <div class="form-group">
            <BbLabel>Description</BbLabel>
            <BbInput @bind-Value="editDescription" />
        </div>
        <BbDialogFooter>
            <BbDialogClose>
                <BbButton Variant="ButtonVariant.Outline">Cancel</BbButton>
            </BbDialogClose>
            <BbButton Variant="ButtonVariant.Default" @onclick="SaveEditAsync">Save</BbButton>
        </BbDialogFooter>
    </BbDialogContent>
</BbDialog>

<BbAlertDialog @bind-Open="showDeleteConfirm">
    <BbAlertDialogContent>
        <BbAlertDialogHeader>
            <BbAlertDialogTitle>Delete IP Rule</BbAlertDialogTitle>
            <BbAlertDialogDescription>This will permanently remove this IP access rule.</BbAlertDialogDescription>
        </BbAlertDialogHeader>
        <BbAlertDialogFooter>
            <BbAlertDialogCancel>
                <BbButton Variant="ButtonVariant.Outline">Cancel</BbButton>
            </BbAlertDialogCancel>
            <BbAlertDialogAction>
                <BbButton Variant="ButtonVariant.Destructive" @onclick="ConfirmDeleteAsync">Delete</BbButton>
            </BbAlertDialogAction>
        </BbAlertDialogFooter>
    </BbAlertDialogContent>
</BbAlertDialog>

<BbDialog @bind-Open="showHelp">
    <BbDialogContent>
        <BbDialogHeader>
            <BbDialogTitle>About IP Access Rules</BbDialogTitle>
            <BbDialogDescription>Network-level access control for SMTP connections</BbDialogDescription>
        </BbDialogHeader>
        <div style="font-size:0.875rem;line-height:1.6;">
            <p>IP access rules control which networks can connect to the SMTP relay. Rules are evaluated in sort order (lowest first).</p>
            <p>Use <strong>CIDR notation</strong> to specify networks, e.g. <code>10.0.0.0/8</code> for all 10.x.x.x addresses, or <code>192.168.1.5/32</code> for a single host.</p>
            <p>If no rules are defined, all connections are accepted (relying on authentication only).</p>
        </div>
        <BbDialogFooter>
            <BbDialogClose>
                <BbButton Variant="ButtonVariant.Outline">Close</BbButton>
            </BbDialogClose>
        </BbDialogFooter>
    </BbDialogContent>
</BbDialog>

@code {
    private IReadOnlyList<IpAccessRule> rules = [];
    private bool isLoading = true;
    private bool showHelp;
    private bool isEditOpen;
    private bool showDeleteConfirm;
    private int deleteTargetId;
    private string? statusMessage;

    private string newNetwork = "";
    private string newAction = "Allow";
    private string newDescription = "";

    private int editId;
    private string editNetwork = "";
    private string editAction = "Allow";
    private string editSortOrder = "0";
    private string editDescription = "";

    protected override async Task OnInitializedAsync() => await RefreshAsync();

    private async Task RefreshAsync()
    {
        isLoading = true;
        using var scope = ScopeFactory.CreateScope();
        var svc = scope.ServiceProvider.GetRequiredService<IIpAccessRuleService>();
        rules = await svc.GetAllAsync();
        isLoading = false;
    }

    private async Task CreateAsync()
    {
        using var scope = ScopeFactory.CreateScope();
        var svc = scope.ServiceProvider.GetRequiredService<IIpAccessRuleService>();

        var nextOrder = rules.Count > 0 ? rules.Max(r => r.SortOrder) + 1 : 1;
        await svc.CreateAsync(new IpAccessRule
        {
            Network = newNetwork.Trim(),
            Action = Enum.Parse<IpAccessAction>(newAction),
            SortOrder = nextOrder,
            Description = string.IsNullOrWhiteSpace(newDescription) ? null : newDescription.Trim()
        });

        statusMessage = "Rule added";
        newNetwork = "";
        newDescription = "";
        await RefreshAsync();
    }

    private void StartEdit(IpAccessRule rule)
    {
        editId = rule.Id;
        editNetwork = rule.Network;
        editAction = rule.Action.ToString();
        editSortOrder = rule.SortOrder.ToString();
        editDescription = rule.Description ?? "";
        isEditOpen = true;
    }

    private async Task SaveEditAsync()
    {
        using var scope = ScopeFactory.CreateScope();
        var svc = scope.ServiceProvider.GetRequiredService<IIpAccessRuleService>();

        await svc.UpdateAsync(new IpAccessRule
        {
            Id = editId,
            Network = editNetwork.Trim(),
            Action = Enum.Parse<IpAccessAction>(editAction),
            SortOrder = int.TryParse(editSortOrder, out var s) ? s : 0,
            Description = string.IsNullOrWhiteSpace(editDescription) ? null : editDescription.Trim()
        });

        statusMessage = "Rule updated";
        isEditOpen = false;
        await RefreshAsync();
    }

    private async Task ConfirmDeleteAsync()
    {
        using var scope = ScopeFactory.CreateScope();
        var svc = scope.ServiceProvider.GetRequiredService<IIpAccessRuleService>();
        await svc.DeleteAsync(deleteTargetId);
        statusMessage = "Rule deleted";
        showDeleteConfirm = false;
        await RefreshAsync();
    }
}
