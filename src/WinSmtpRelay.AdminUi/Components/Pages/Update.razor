@page "/update"
@using System.Text.Json
@inject IHttpClientFactory HttpClientFactory

<BbBreadcrumb>
    <BbBreadcrumbList AutoSeparator="true">
        <BbBreadcrumbItem>
            <BbBreadcrumbLink Href="/">Home</BbBreadcrumbLink>
        </BbBreadcrumbItem>
        <BbBreadcrumbItem>
            <BbBreadcrumbPage>Update</BbBreadcrumbPage>
        </BbBreadcrumbItem>
    </BbBreadcrumbList>
</BbBreadcrumb>

<h2>Software Update</h2>
<p class="text-muted">Check for new WinSmtpRelay releases on GitHub</p>

<BbCard Class="mb-1">
    <BbCardHeader><BbCardTitle>Current Version</BbCardTitle></BbCardHeader>
    <BbCardContent>
        <p><strong>@currentVersion</strong></p>
    </BbCardContent>
</BbCard>

<BbCard>
    <BbCardHeader><BbCardTitle>Latest Release</BbCardTitle></BbCardHeader>
    <BbCardContent>
        @if (isChecking)
        {
            <div style="display:flex;align-items:center;gap:0.5rem;">
                <BbSpinner />
                <span class="text-muted">Checking for updates...</span>
            </div>
        }
        else if (errorMessage is not null)
        {
            <BbAlert>@errorMessage</BbAlert>
            <BbButton Variant="ButtonVariant.Outline" @onclick="CheckForUpdates" Class="mt-1">
                <LucideIcon Name="refresh-cw" />
                Retry
            </BbButton>
        }
        else if (latestRelease is not null)
        {
            <p>
                <strong>@latestRelease.TagName</strong>
                @if (isNewer)
                {
                    <BbBadge Variant="BadgeVariant.Destructive" Class="ml-1">Update Available</BbBadge>
                }
                else
                {
                    <BbBadge Variant="BadgeVariant.Default" Class="ml-1">Up to date</BbBadge>
                }
            </p>
            <p>@latestRelease.Name</p>
            <p class="text-muted">Published: @latestRelease.PublishedAt?.ToString("yyyy-MM-dd HH:mm")</p>

            @if (latestRelease.Assets.Count > 0)
            {
                <BbSeparator Class="my-1" />
                <h4>Downloads</h4>
                <table>
                    <thead>
                        <tr>
                            <th>File</th>
                            <th>Size</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var asset in latestRelease.Assets)
                        {
                            <tr>
                                <td>
                                    <a href="@asset.DownloadUrl" target="_blank">
                                        <LucideIcon Name="download" />
                                        @asset.Name
                                    </a>
                                </td>
                                <td class="text-muted">@FormatSize(asset.Size)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }

            @if (!string.IsNullOrEmpty(latestRelease.Body))
            {
                <BbSeparator Class="my-1" />
                <h4>Release Notes</h4>
                <pre style="white-space:pre-wrap;font-size:0.85rem;max-height:300px;overflow-y:auto;">@latestRelease.Body</pre>
            }
        }
        else
        {
            <BbButton Variant="ButtonVariant.Default" @onclick="CheckForUpdates">
                <LucideIcon Name="download" />
                Check for Updates
            </BbButton>
        }
    </BbCardContent>
</BbCard>

@code {
    private string currentVersion = typeof(Update).Assembly.GetName().Version?.ToString() ?? "0.0.0";
    private bool isChecking;
    private string? errorMessage;
    private GitHubRelease? latestRelease;
    private bool isNewer;

    private async Task CheckForUpdates()
    {
        isChecking = true;
        errorMessage = null;
        latestRelease = null;
        StateHasChanged();

        try
        {
            var client = HttpClientFactory.CreateClient();
            client.DefaultRequestHeaders.Add("User-Agent", "WinSmtpRelay-Admin");
            client.Timeout = TimeSpan.FromSeconds(15);

            var response = await client.GetAsync("https://api.github.com/repos/ardimedia/winsmtprelay/releases/latest");
            if (!response.IsSuccessStatusCode)
            {
                errorMessage = $"GitHub API returned {response.StatusCode}. No releases published yet?";
                return;
            }

            var json = await response.Content.ReadAsStringAsync();
            latestRelease = JsonSerializer.Deserialize<GitHubRelease>(json, new JsonSerializerOptions
            {
                PropertyNameCaseInsensitive = true
            });

            if (latestRelease is not null)
            {
                var latestVer = latestRelease.TagName?.TrimStart('v') ?? "0.0.0";
                isNewer = string.Compare(latestVer, currentVersion, StringComparison.OrdinalIgnoreCase) > 0;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to check: {ex.Message}";
        }
        finally
        {
            isChecking = false;
        }
    }

    private static string FormatSize(long bytes) => bytes switch
    {
        >= 1_048_576 => $"{bytes / 1_048_576.0:F1} MB",
        >= 1024 => $"{bytes / 1024.0:F0} KB",
        _ => $"{bytes} B"
    };

    private class GitHubRelease
    {
        public string? TagName { get; set; }
        public string? Name { get; set; }
        public string? Body { get; set; }
        public DateTime? PublishedAt { get; set; }
        public bool Prerelease { get; set; }
        public List<GitHubAsset> Assets { get; set; } = [];
    }

    private class GitHubAsset
    {
        public string Name { get; set; } = "";
        public string BrowserDownloadUrl { get; set; } = "";
        public string DownloadUrl => BrowserDownloadUrl;
        public long Size { get; set; }
    }
}
