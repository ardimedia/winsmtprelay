@page "/connectors/receive"
@using WinSmtpRelay.Core.Interfaces
@using WinSmtpRelay.Core.Models
@inject IServiceScopeFactory ScopeFactory

<BbBreadcrumb>
    <BbBreadcrumbList>
        <BbBreadcrumbItem>
            <BbBreadcrumbLink Href="/">Home</BbBreadcrumbLink>
        </BbBreadcrumbItem>
        <BbBreadcrumbSeparator />
        <BbBreadcrumbItem>
            <BbBreadcrumbPage>Receive Connectors</BbBreadcrumbPage>
        </BbBreadcrumbItem>
    </BbBreadcrumbList>
</BbBreadcrumb>

<div class="page-header page-header-row">
    <div>
        <h1>Receive Connectors</h1>
        <p>SMTP listener endpoints &mdash; changes require a service restart to take effect</p>
    </div>
    <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" @onclick="() => showHelp = true">
        <LucideIcon Name="info" /> About Receive Connectors
    </BbButton>
</div>

<div style="max-width:500px;">
<BbCard Class="mb-1">
    <BbCardHeader>
        <BbCardTitle>Create Connector</BbCardTitle>
    </BbCardHeader>
    <BbCardContent>
        <div class="form-group">
            <BbLabel>Name</BbLabel>
            <BbInput @bind-Value="newName" Placeholder="Default" />
        </div>
        <div style="display:flex;gap:1rem;">
            <div class="form-group" style="flex:2">
                <BbLabel>Bind Address</BbLabel>
                <BbInput @bind-Value="newAddress" Placeholder="0.0.0.0" />
            </div>
            <div class="form-group" style="flex:1">
                <BbLabel>Port</BbLabel>
                <BbInput Type="InputType.Number" @bind-Value="newPort" />
            </div>
        </div>
        <div style="display:flex;gap:1rem;">
            <div class="form-group">
                <BbLabel>Require TLS</BbLabel>
                <BbNativeSelect @bind-Value="newRequireTls">
                    <option value="false">No</option>
                    <option value="true">Yes (STARTTLS)</option>
                </BbNativeSelect>
            </div>
            <div class="form-group">
                <BbLabel>Implicit TLS</BbLabel>
                <BbNativeSelect @bind-Value="newImplicitTls">
                    <option value="false">No</option>
                    <option value="true">Yes</option>
                </BbNativeSelect>
            </div>
            <div class="form-group">
                <BbLabel>Require Auth</BbLabel>
                <BbNativeSelect @bind-Value="newRequireAuth">
                    <option value="false">No</option>
                    <option value="true">Yes</option>
                </BbNativeSelect>
            </div>
        </div>
    </BbCardContent>
    <BbCardFooter>
        <BbButton Variant="ButtonVariant.Default" @onclick="CreateAsync"
                Disabled="@string.IsNullOrWhiteSpace(newName)">
            <LucideIcon Name="plus" /> Create
        </BbButton>
        @if (!string.IsNullOrEmpty(statusMessage))
        {
            <span class="text-muted" style="margin-left:1rem">@statusMessage</span>
        }
    </BbCardFooter>
</BbCard>
</div>

@if (isLoading)
{
    <BbSkeleton Class="h-[300px] w-full" />
}
else
{
    <BbTable Data="@connectors">
        <BbTableHeader>
            <BbTableRow TData="ReceiveConnector">
                <BbTableHeaderCell TData="ReceiveConnector">Name</BbTableHeaderCell>
                <BbTableHeaderCell TData="ReceiveConnector">Endpoint</BbTableHeaderCell>
                <BbTableHeaderCell TData="ReceiveConnector">TLS</BbTableHeaderCell>
                <BbTableHeaderCell TData="ReceiveConnector">Auth</BbTableHeaderCell>
                <BbTableHeaderCell TData="ReceiveConnector">Max Size</BbTableHeaderCell>
                <BbTableHeaderCell TData="ReceiveConnector">Enabled</BbTableHeaderCell>
                <BbTableHeaderCell TData="ReceiveConnector">Actions</BbTableHeaderCell>
            </BbTableRow>
        </BbTableHeader>
        <BbTableBody>
            @if (connectors.Count == 0)
            {
                <BbTableRow TData="ReceiveConnector">
                    <BbTableCell colspan="7" style="text-align:center;">No receive connectors configured</BbTableCell>
                </BbTableRow>
            }
            @foreach (var c in connectors)
            {
                <BbTableRow Item="@c">
                    <BbTableCell>@c.Name</BbTableCell>
                    <BbTableCell><code>@c.Address:@c.Port</code></BbTableCell>
                    <BbTableCell>
                        @if (c.ImplicitTls) { <span>Implicit</span> }
                        else if (c.RequireTls) { <span>STARTTLS</span> }
                        else { <span class="text-muted">None</span> }
                    </BbTableCell>
                    <BbTableCell><span class="badge-status @(c.RequireAuth ? "badge-success" : "badge-muted")">@(c.RequireAuth ? "Yes" : "No")</span></BbTableCell>
                    <BbTableCell>@(c.MaxMessageSizeBytes / (1024 * 1024)) MB</BbTableCell>
                    <BbTableCell><span class="badge-status @(c.IsEnabled ? "badge-success" : "badge-muted")">@(c.IsEnabled ? "Yes" : "No")</span></BbTableCell>
                    <BbTableCell>
                        <BbDropdownMenu>
                            <BbDropdownMenuTrigger>
                                <BbButton Size="ButtonSize.Small" Variant="ButtonVariant.Ghost">
                                    <LucideIcon Name="ellipsis" />
                                </BbButton>
                            </BbDropdownMenuTrigger>
                            <BbDropdownMenuContent>
                                <BbDropdownMenuItem @onclick="() => StartEdit(c)">
                                    <LucideIcon Name="pencil" /> Edit
                                </BbDropdownMenuItem>
                                <BbDropdownMenuSeparator />
                                <BbDropdownMenuItem @onclick="() => { deleteTargetId = c.Id; showDeleteConfirm = true; }">
                                    <LucideIcon Name="trash-2" /> Delete
                                </BbDropdownMenuItem>
                            </BbDropdownMenuContent>
                        </BbDropdownMenu>
                    </BbTableCell>
                </BbTableRow>
            }
        </BbTableBody>
    </BbTable>
}

<BbDialog @bind-Open="isEditOpen">
    <BbDialogContent>
        <BbDialogHeader>
            <BbDialogTitle>Edit: @editName</BbDialogTitle>
            <BbDialogDescription>Modify receive connector settings</BbDialogDescription>
        </BbDialogHeader>
        <div class="form-group">
            <BbLabel>Name</BbLabel>
            <BbInput @bind-Value="editName" />
        </div>
        <div style="display:flex;gap:1rem;">
            <div class="form-group" style="flex:2">
                <BbLabel>Bind Address</BbLabel>
                <BbInput @bind-Value="editAddress" />
            </div>
            <div class="form-group" style="flex:1">
                <BbLabel>Port</BbLabel>
                <BbInput Type="InputType.Number" @bind-Value="editPort" />
            </div>
        </div>
        <div style="display:flex;gap:1rem;">
            <div class="form-group">
                <BbLabel>Require TLS</BbLabel>
                <BbNativeSelect @bind-Value="editRequireTls">
                    <option value="false">No</option>
                    <option value="true">Yes</option>
                </BbNativeSelect>
            </div>
            <div class="form-group">
                <BbLabel>Implicit TLS</BbLabel>
                <BbNativeSelect @bind-Value="editImplicitTls">
                    <option value="false">No</option>
                    <option value="true">Yes</option>
                </BbNativeSelect>
            </div>
            <div class="form-group">
                <BbLabel>Require Auth</BbLabel>
                <BbNativeSelect @bind-Value="editRequireAuth">
                    <option value="false">No</option>
                    <option value="true">Yes</option>
                </BbNativeSelect>
            </div>
        </div>
        <div style="display:flex;gap:1rem;">
            <div class="form-group" style="flex:1">
                <BbLabel>Max Message Size (MB)</BbLabel>
                <BbInput Type="InputType.Number" @bind-Value="editMaxSizeMb" />
            </div>
            <div class="form-group" style="flex:1">
                <BbLabel>Max Connections</BbLabel>
                <BbInput Type="InputType.Number" @bind-Value="editMaxConn" />
            </div>
        </div>
        <div class="form-group">
            <BbLabel>Enabled</BbLabel>
            <BbNativeSelect @bind-Value="editEnabled">
                <option value="true">Yes</option>
                <option value="false">No</option>
            </BbNativeSelect>
        </div>
        <BbDialogFooter>
            <BbDialogClose>
                <BbButton Variant="ButtonVariant.Outline">Cancel</BbButton>
            </BbDialogClose>
            <BbButton Variant="ButtonVariant.Default" @onclick="SaveEditAsync">Save</BbButton>
        </BbDialogFooter>
    </BbDialogContent>
</BbDialog>

<BbAlertDialog @bind-Open="showDeleteConfirm">
    <BbAlertDialogContent>
        <BbAlertDialogHeader>
            <BbAlertDialogTitle>Delete Receive Connector</BbAlertDialogTitle>
            <BbAlertDialogDescription>This will remove this SMTP endpoint. A service restart is required for changes to take effect.</BbAlertDialogDescription>
        </BbAlertDialogHeader>
        <BbAlertDialogFooter>
            <BbAlertDialogCancel>
                <BbButton Variant="ButtonVariant.Outline">Cancel</BbButton>
            </BbAlertDialogCancel>
            <BbAlertDialogAction>
                <BbButton Variant="ButtonVariant.Destructive" @onclick="ConfirmDeleteAsync">Delete</BbButton>
            </BbAlertDialogAction>
        </BbAlertDialogFooter>
    </BbAlertDialogContent>
</BbAlertDialog>

<BbDialog @bind-Open="showHelp">
    <BbDialogContent>
        <BbDialogHeader>
            <BbDialogTitle>About Receive Connectors</BbDialogTitle>
            <BbDialogDescription>SMTP listener endpoints</BbDialogDescription>
        </BbDialogHeader>
        <div style="font-size:0.875rem;line-height:1.6;">
            <p>Receive connectors define the SMTP endpoints that WinSmtpRelay listens on for incoming email.</p>
            <h4 style="margin-top:1rem;">Common configurations</h4>
            <ul style="padding-left:1.25rem;">
                <li><strong>Port 25</strong> &mdash; Standard SMTP (no auth, for internal relay)</li>
                <li><strong>Port 587</strong> &mdash; Submission (STARTTLS + auth required)</li>
                <li><strong>Port 465</strong> &mdash; SMTPS (Implicit TLS + auth required)</li>
            </ul>
            <p style="margin-top:1rem;"><strong>Note:</strong> Changes to receive connectors require a service restart to take effect.</p>
        </div>
        <BbDialogFooter>
            <BbDialogClose>
                <BbButton Variant="ButtonVariant.Outline">Close</BbButton>
            </BbDialogClose>
        </BbDialogFooter>
    </BbDialogContent>
</BbDialog>

@code {
    private IReadOnlyList<ReceiveConnector> connectors = [];
    private bool isLoading = true;
    private bool showHelp;
    private bool isEditOpen;
    private bool showDeleteConfirm;
    private int deleteTargetId;
    private string? statusMessage;

    // Create form
    private string newName = "";
    private string newAddress = "0.0.0.0";
    private string newPort = "25";
    private string newRequireTls = "false";
    private string newImplicitTls = "false";
    private string newRequireAuth = "false";

    // Edit form
    private int editId;
    private string editName = "";
    private string editAddress = "";
    private string editPort = "";
    private string editRequireTls = "false";
    private string editImplicitTls = "false";
    private string editRequireAuth = "false";
    private string editMaxSizeMb = "25";
    private string editMaxConn = "100";
    private string editEnabled = "true";

    protected override async Task OnInitializedAsync() => await RefreshAsync();

    private async Task RefreshAsync()
    {
        isLoading = true;
        using var scope = ScopeFactory.CreateScope();
        var svc = scope.ServiceProvider.GetRequiredService<IReceiveConnectorService>();
        connectors = await svc.GetAllAsync();
        isLoading = false;
    }

    private async Task CreateAsync()
    {
        using var scope = ScopeFactory.CreateScope();
        var svc = scope.ServiceProvider.GetRequiredService<IReceiveConnectorService>();

        await svc.CreateAsync(new ReceiveConnector
        {
            Name = newName.Trim(),
            Address = newAddress.Trim(),
            Port = int.TryParse(newPort, out var p) ? p : 25,
            RequireTls = newRequireTls == "true",
            ImplicitTls = newImplicitTls == "true",
            RequireAuth = newRequireAuth == "true"
        });

        statusMessage = $"Connector '{newName}' created (restart required)";
        newName = "";
        newAddress = "0.0.0.0";
        newPort = "25";
        newRequireTls = "false";
        newImplicitTls = "false";
        newRequireAuth = "false";
        await RefreshAsync();
    }

    private void StartEdit(ReceiveConnector c)
    {
        editId = c.Id;
        editName = c.Name;
        editAddress = c.Address;
        editPort = c.Port.ToString();
        editRequireTls = c.RequireTls.ToString().ToLowerInvariant();
        editImplicitTls = c.ImplicitTls.ToString().ToLowerInvariant();
        editRequireAuth = c.RequireAuth.ToString().ToLowerInvariant();
        editMaxSizeMb = (c.MaxMessageSizeBytes / (1024 * 1024)).ToString();
        editMaxConn = c.MaxConnections.ToString();
        editEnabled = c.IsEnabled.ToString().ToLowerInvariant();
        isEditOpen = true;
    }

    private async Task SaveEditAsync()
    {
        using var scope = ScopeFactory.CreateScope();
        var svc = scope.ServiceProvider.GetRequiredService<IReceiveConnectorService>();

        await svc.UpdateAsync(new ReceiveConnector
        {
            Id = editId,
            Name = editName.Trim(),
            Address = editAddress.Trim(),
            Port = int.TryParse(editPort, out var p) ? p : 25,
            RequireTls = editRequireTls == "true",
            ImplicitTls = editImplicitTls == "true",
            RequireAuth = editRequireAuth == "true",
            MaxMessageSizeBytes = (int.TryParse(editMaxSizeMb, out var s) ? s : 25) * 1024 * 1024,
            MaxConnections = int.TryParse(editMaxConn, out var mc) ? mc : 100,
            IsEnabled = editEnabled == "true"
        });

        statusMessage = "Connector updated (restart required)";
        isEditOpen = false;
        await RefreshAsync();
    }

    private async Task ConfirmDeleteAsync()
    {
        using var scope = ScopeFactory.CreateScope();
        var svc = scope.ServiceProvider.GetRequiredService<IReceiveConnectorService>();
        await svc.DeleteAsync(deleteTargetId);
        statusMessage = "Connector deleted (restart required)";
        showDeleteConfirm = false;
        await RefreshAsync();
    }
}
