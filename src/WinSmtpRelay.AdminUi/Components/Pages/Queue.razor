@page "/queue"
@using WinSmtpRelay.Core.Interfaces
@using WinSmtpRelay.Core.Models
@inject IServiceScopeFactory ScopeFactory

<BbBreadcrumb>
    <BbBreadcrumbList>
        <BbBreadcrumbItem>
            <BbBreadcrumbLink Href="/">Home</BbBreadcrumbLink>
        </BbBreadcrumbItem>
        <BbBreadcrumbSeparator />
        <BbBreadcrumbItem>
            <BbBreadcrumbPage>Queue</BbBreadcrumbPage>
        </BbBreadcrumbItem>
    </BbBreadcrumbList>
</BbBreadcrumb>

<div class="page-header page-header-row">
    <div>
        <h1>Message Queue</h1>
        <p>Queued, pending, and failed messages</p>
    </div>
    <div style="display:flex;gap:0.5rem;">
        <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" @onclick="() => showHelp = true">
            <LucideIcon Name="info" /> About this page
        </BbButton>
        <BbButton Variant="ButtonVariant.Default" @onclick="RefreshAsync">
            <LucideIcon Name="refresh-cw" /> Refresh
        </BbButton>
    </div>
</div>

@if (!loaded)
{
    <BbSkeleton Class="h-[300px] w-full" />
}
else
{
    <BbTable Data="@messages">
        <BbTableHeader>
            <BbTableRow TData="QueuedMessage">
                <BbTableHeaderCell TData="QueuedMessage">ID</BbTableHeaderCell>
                <BbTableHeaderCell TData="QueuedMessage">Message-ID</BbTableHeaderCell>
                <BbTableHeaderCell TData="QueuedMessage">Sender</BbTableHeaderCell>
                <BbTableHeaderCell TData="QueuedMessage">Recipients</BbTableHeaderCell>
                <BbTableHeaderCell TData="QueuedMessage">Size</BbTableHeaderCell>
                <BbTableHeaderCell TData="QueuedMessage">Status</BbTableHeaderCell>
                <BbTableHeaderCell TData="QueuedMessage">Retries</BbTableHeaderCell>
                <BbTableHeaderCell TData="QueuedMessage">Created</BbTableHeaderCell>
                <BbTableHeaderCell TData="QueuedMessage">Actions</BbTableHeaderCell>
            </BbTableRow>
        </BbTableHeader>
        <BbTableBody>
            @if (messages.Count == 0)
            {
                <BbTableRow TData="QueuedMessage">
                    <BbTableCell colspan="9" class="text-muted">Queue is empty</BbTableCell>
                </BbTableRow>
            }
            @foreach (var msg in messages)
            {
                <BbTableRow Item="@msg">
                    <BbTableCell class="mono">@msg.Id</BbTableCell>
                    <BbTableCell>
                        <BbTooltip>
                            <BbTooltipTrigger>
                                <span class="mono" style="max-width:200px;overflow:hidden;text-overflow:ellipsis;display:inline-block;">@msg.MessageId</span>
                            </BbTooltipTrigger>
                            <BbTooltipContent>@msg.MessageId</BbTooltipContent>
                        </BbTooltip>
                    </BbTableCell>
                    <BbTableCell>@msg.Sender</BbTableCell>
                    <BbTableCell>@msg.Recipients</BbTableCell>
                    <BbTableCell>@FormatSize(msg.SizeBytes)</BbTableCell>
                    <BbTableCell><span class="badge-status @GetBadgeCss(msg.Status)">@msg.Status</span></BbTableCell>
                    <BbTableCell>@msg.RetryCount</BbTableCell>
                    <BbTableCell>@msg.CreatedUtc.ToString("yyyy-MM-dd HH:mm")</BbTableCell>
                    <BbTableCell>
                        <BbDropdownMenu>
                            <BbDropdownMenuTrigger>
                                <BbButton Size="ButtonSize.Small" Variant="ButtonVariant.Ghost">
                                    <LucideIcon Name="ellipsis" />
                                </BbButton>
                            </BbDropdownMenuTrigger>
                            <BbDropdownMenuContent>
                                @if (msg.Status is MessageStatus.Failed or MessageStatus.Bounced)
                                {
                                    <BbDropdownMenuItem @onclick="() => RetryAsync(msg.Id)">
                                        <LucideIcon Name="rotate-ccw" /> Retry
                                    </BbDropdownMenuItem>
                                    <BbDropdownMenuSeparator />
                                }
                                <BbDropdownMenuItem @onclick="() => { deleteTargetId = msg.Id; showDeleteConfirm = true; }">
                                    <LucideIcon Name="trash-2" /> Delete
                                </BbDropdownMenuItem>
                            </BbDropdownMenuContent>
                        </BbDropdownMenu>
                    </BbTableCell>
                </BbTableRow>
            }
        </BbTableBody>
    </BbTable>
}

@if (!string.IsNullOrEmpty(statusMessage))
{
    <BbAlert Class="mt-1">@statusMessage</BbAlert>
}

<BbAlertDialog @bind-Open="showDeleteConfirm">
    <BbAlertDialogContent>
        <BbAlertDialogHeader>
            <BbAlertDialogTitle>Delete Message</BbAlertDialogTitle>
            <BbAlertDialogDescription>This will permanently remove the message from the queue. This action cannot be undone.</BbAlertDialogDescription>
        </BbAlertDialogHeader>
        <BbAlertDialogFooter>
            <BbAlertDialogCancel>
                <BbButton Variant="ButtonVariant.Outline">Cancel</BbButton>
            </BbAlertDialogCancel>
            <BbAlertDialogAction>
                <BbButton Variant="ButtonVariant.Destructive" @onclick="ConfirmDeleteAsync">Delete</BbButton>
            </BbAlertDialogAction>
        </BbAlertDialogFooter>
    </BbAlertDialogContent>
</BbAlertDialog>

<BbDialog @bind-Open="showHelp">
    <BbDialogContent>
        <BbDialogHeader>
            <BbDialogTitle>About the Message Queue</BbDialogTitle>
            <BbDialogDescription>Understanding message processing</BbDialogDescription>
        </BbDialogHeader>
        <div style="font-size:0.875rem;line-height:1.6;">
            <p>
                Every email submitted to WinSmtpRelay is first stored in a persistent queue (SQLite database)
                before delivery is attempted. This page shows messages that are waiting, being delivered, or have failed.
            </p>
            <h4 style="margin-top:1rem;">Message lifecycle</h4>
            <ol style="padding-left:1.25rem;">
                <li><strong>Queued</strong> &mdash; message received and waiting for the delivery worker to pick it up.</li>
                <li><strong>Delivering</strong> &mdash; currently being sent to the recipient's mail server.</li>
                <li><strong>Delivered</strong> &mdash; successfully accepted by the remote server (disappears from this view).</li>
                <li><strong>Failed/Bounced</strong> &mdash; delivery failed permanently after all retry attempts.</li>
            </ol>
            <h4 style="margin-top:1rem;">Actions</h4>
            <ul style="padding-left:1.25rem;">
                <li><strong>Retry</strong> &mdash; re-queue a failed/bounced message for another delivery attempt.</li>
                <li><strong>Delete</strong> &mdash; permanently remove a message from the queue.</li>
            </ul>
            <h4 style="margin-top:1rem;">Retries</h4>
            <p>
                The relay automatically retries delivery on temporary failures using configurable intervals
                (e.g., 1, 5, 15, 30, 60 minutes). After the maximum retry window (default 48 hours),
                the message is bounced.
            </p>
        </div>
        <BbDialogFooter>
            <BbDialogClose>
                <BbButton Variant="ButtonVariant.Outline">Close</BbButton>
            </BbDialogClose>
        </BbDialogFooter>
    </BbDialogContent>
</BbDialog>

@code {
    private bool showHelp;
    private IReadOnlyList<QueuedMessage> messages = [];
    private string? statusMessage;
    private bool loaded;
    private bool showDeleteConfirm;
    private long deleteTargetId;

    protected override async Task OnInitializedAsync() => await RefreshAsync();

    private async Task RefreshAsync()
    {
        using var scope = ScopeFactory.CreateScope();
        var queue = scope.ServiceProvider.GetRequiredService<IMessageQueue>();
        messages = await queue.GetPendingAsync(100);
        statusMessage = null;
        loaded = true;
    }

    private async Task RetryAsync(long id)
    {
        using var scope = ScopeFactory.CreateScope();
        var queue = scope.ServiceProvider.GetRequiredService<IMessageQueue>();
        await queue.UpdateStatusAsync(id, MessageStatus.Queued);
        await queue.SetRetryAsync(id, 0, DateTime.UtcNow);
        statusMessage = $"Message {id} re-queued for delivery";
        await RefreshAsync();
    }

    private async Task ConfirmDeleteAsync()
    {
        await DeleteAsync(deleteTargetId);
        showDeleteConfirm = false;
    }

    private async Task DeleteAsync(long id)
    {
        using var scope = ScopeFactory.CreateScope();
        var queue = scope.ServiceProvider.GetRequiredService<IMessageQueue>();
        await queue.DeleteAsync(id);
        statusMessage = $"Message {id} deleted";
        await RefreshAsync();
    }

    private static string FormatSize(int bytes) => bytes switch
    {
        < 1024 => $"{bytes} B",
        < 1024 * 1024 => $"{bytes / 1024.0:F1} KB",
        _ => $"{bytes / (1024.0 * 1024):F1} MB"
    };

    private static string GetBadgeCss(MessageStatus status) => status switch
    {
        MessageStatus.Delivered => "badge-success",
        MessageStatus.Failed or MessageStatus.Bounced => "badge-error",
        MessageStatus.Queued => "badge-muted",
        _ => "badge-muted"
    };
}
