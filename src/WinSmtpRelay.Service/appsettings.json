{
  "ConnectionStrings": {
    "RelayDb": "Data Source=winsmtprelay.db"
  },
  "SmtpListener": {
    "Endpoints": [
      {
        "Address": "0.0.0.0",
        "Port": 25,
        "RequireTls": false,
        "ImplicitTls": false,
        "RequireAuth": false
      }
    ],
    "MaxMessageSizeBytes": 26214400,
    "MaxConnections": 100,
    "AllowedNetworks": [
      "10.0.0.0/8",
      "192.168.0.0/16",
      "172.16.0.0/12",
      "127.0.0.1/32"
    ],
    "AcceptedDomains": []
  },
  "Tls": {
    "CertificatePath": null,
    "CertificatePassword": null,
    "CertificateThumbprint": null
  },
  "AdminUi": {
    "Enabled": true,
    "Port": 8025,
    "BindAddress": "0.0.0.0"
  },
  "Dkim": {
    "Enabled": false,
    "Domains": []
  },
  "Delivery": {
    "MaxConcurrentDeliveries": 4,
    "MaxRetryHours": 48,
    "RetryIntervalsMinutes": [1, 5, 30, 120, 480, 1440],
    "SmartHost": null,
    "OpportunisticTls": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.EntityFrameworkCore": "Warning"
    },
    "EventLog": {
      "SourceName": "WinSmtpRelay",
      "LogName": "Application"
    }
  }
}
