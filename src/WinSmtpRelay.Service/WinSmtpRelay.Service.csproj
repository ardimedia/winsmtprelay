<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>WinSmtpRelay.Service</RootNamespace>
    <RequiresAspNetWebAssets>true</RequiresAspNetWebAssets>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.EntityFrameworkCore.Design" Version="10.0.3">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="10.0.3" />
    <PackageReference Include="Microsoft.Extensions.Hosting.WindowsServices" Version="10.0.3" />
    <PackageReference Include="System.Drawing.Common" Version="9.0.6" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\WinSmtpRelay.Core\WinSmtpRelay.Core.csproj" />
    <ProjectReference Include="..\WinSmtpRelay.SmtpListener\WinSmtpRelay.SmtpListener.csproj" />
    <ProjectReference Include="..\WinSmtpRelay.Delivery\WinSmtpRelay.Delivery.csproj" />
    <ProjectReference Include="..\WinSmtpRelay.Security\WinSmtpRelay.Security.csproj" />
    <ProjectReference Include="..\WinSmtpRelay.Storage\WinSmtpRelay.Storage.csproj" />
    <ProjectReference Include="..\WinSmtpRelay.AdminApi\WinSmtpRelay.AdminApi.csproj" />
    <ProjectReference Include="..\WinSmtpRelay.AdminUi\WinSmtpRelay.AdminUi.csproj" />
  </ItemGroup>

</Project>
