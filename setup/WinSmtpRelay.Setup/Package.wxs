<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package Name="WinSmtpRelay $(var.VersionLabel)"
           Manufacturer="ARDIMEDIA"
           Version="$(var.ProductVersion)"
           UpgradeCode="2cbb38d8-5035-40db-b30b-0e55f24ec496"
           Scope="perMachine"
           Compressed="yes">

    <SummaryInformation Description="WinSmtpRelay — Open-Source SMTP Relay for Windows" />

    <MajorUpgrade Schedule="afterInstallInitialize"
                  DowngradeErrorMessage="A newer version of WinSmtpRelay is already installed. Please uninstall it first."
                  AllowSameVersionUpgrades="yes" />

    <MediaTemplate EmbedCab="yes" />

    <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />

    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />

    <!-- Detect whether the service was running before upgrade (read during AppSearch, before service is stopped) -->
    <Property Id="SERVICEWASRUNNING">
      <RegistrySearch Id="ServiceWasRunningSearch"
                      Root="HKLM"
                      Key="SOFTWARE\ARDIMEDIA\WinSmtpRelay"
                      Name="ServiceRunning"
                      Type="raw" />
    </Property>

    <!-- Exit dialog: "Start service now?" checkbox -->
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT" Value="Start WinSmtpRelay service now" />
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOX" Value="1" />

    <!-- On upgrade where service was NOT running: uncheck the exit dialog checkbox -->
    <SetProperty Id="WIXUI_EXITDIALOGOPTIONALCHECKBOX"
                 Value="{}"
                 Before="CostFinalize"
                 Sequence="ui"
                 Condition="WIX_UPGRADE_DETECTED AND NOT (SERVICEWASRUNNING = &quot;#1&quot;)" />

    <!-- WixUI ExitDlg triggers DoAction "LaunchApplication" when checkbox is checked -->
    <CustomAction Id="LaunchApplication"
                  Directory="SystemFolder"
                  ExeCommand="sc.exe start WinSmtpRelay"
                  Execute="immediate"
                  Return="ignore"
                  Impersonate="no" />

    <!-- Deferred CA: auto-start service during upgrade if it was running before -->
    <CustomAction Id="StartServiceOnUpgrade"
                  Directory="SystemFolder"
                  ExeCommand="sc.exe start WinSmtpRelay"
                  Execute="deferred"
                  Return="ignore"
                  Impersonate="no" />

    <InstallExecuteSequence>
      <Custom Action="StartServiceOnUpgrade"
              After="StartServices"
              Condition="WIX_UPGRADE_DETECTED AND (SERVICEWASRUNNING = &quot;#1&quot;)" />
    </InstallExecuteSequence>

    <!-- .NET 10 runtime check for framework-dependent variant -->
    <?if $(var.SelfContained) = false ?>
    <Property Id="NETCORERUNTIME10">
      <RegistrySearch Id="NetCore10Search"
                      Root="HKLM"
                      Key="SOFTWARE\dotnet\Setup\InstalledVersions\x64\sharedhost"
                      Name="Version"
                      Type="raw" />
    </Property>
    <Launch Condition="Installed OR NETCORERUNTIME10"
            Message="WinSmtpRelay requires the .NET 10 Runtime (x64). Please download and install it from https://dotnet.microsoft.com/download/dotnet/10.0 and run this installer again." />
    <?endif?>

    <!-- Directory structure -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="WinSmtpRelay" />
    </StandardDirectory>

    <!-- Single feature containing all components -->
    <Feature Id="Complete" Title="WinSmtpRelay" Level="1">
      <ComponentRef Id="ServiceComponent" />
      <ComponentRef Id="ConfigComponent" />
      <ComponentRef Id="FirewallRules" />
      <ComponentRef Id="EventLogSource" />
      <ComponentRef Id="InstallDirPermissions" />

      <!-- Auto-harvested published files -->
      <Files Directory="INSTALLFOLDER" Include="$(var.HarvestPath)**">
        <Exclude Files="$(var.HarvestPath)appsettings.json" />
        <Exclude Files="$(var.HarvestPath)appsettings.Development.json" />
        <Exclude Files="$(var.HarvestPath)WinSmtpRelay.Service.exe" />
      </Files>
    </Feature>

  </Package>

</Wix>
